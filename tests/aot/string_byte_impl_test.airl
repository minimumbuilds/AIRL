;; Test byte-based string implementations (pure AIRL stdlib)
;; Rust builtins deregistered — these are now the canonical implementations

;; ── starts-with ──
(let (t1a : bool (starts-with "hello world" "hello"))
     (t1b : bool (starts-with "hello world" "world"))
     (t1c : bool (starts-with "hello" "hello world"))
     (t1d : bool (starts-with "" ""))
     (t1e : bool (starts-with "abc" ""))
  (do (assert (= t1a true)  "starts-with: 'hello world' starts with 'hello'")
      (assert (= t1b false) "starts-with: 'hello world' does not start with 'world'")
      (assert (= t1c false) "starts-with: prefix longer than string")
      (assert (= t1d true)  "starts-with: empty string starts with empty")
      (assert (= t1e true)  "starts-with: any string starts with empty")
      (print "starts-with: PASS\n")))

;; ── ends-with ──
(let (t2a : bool (ends-with "hello world" "world"))
     (t2b : bool (ends-with "hello world" "hello"))
     (t2c : bool (ends-with "hello" "hello world"))
     (t2d : bool (ends-with "" ""))
     (t2e : bool (ends-with "abc" ""))
  (do (assert (= t2a true)  "ends-with: 'hello world' ends with 'world'")
      (assert (= t2b false) "ends-with: 'hello world' does not end with 'hello'")
      (assert (= t2c false) "ends-with: suffix longer than string")
      (assert (= t2d true)  "ends-with: empty string ends with empty")
      (assert (= t2e true)  "ends-with: any string ends with empty")
      (print "ends-with: PASS\n")))

;; ── contains ──
(let (t3a : bool (contains "hello world" "lo wo"))
     (t3b : bool (contains "hello world" "xyz"))
     (t3c : bool (contains "hello" "hello"))
     (t3d : bool (contains "abc" ""))
     (t3e : bool (contains "" "x"))
  (do (assert (= t3a true)  "contains: 'hello world' contains 'lo wo'")
      (assert (= t3b false) "contains: 'hello world' does not contain 'xyz'")
      (assert (= t3c true)  "contains: exact match")
      (assert (= t3d true)  "contains: any string contains empty")
      (assert (= t3e false) "contains: empty string contains nothing")
      (print "contains: PASS\n")))

;; ── index-of ──
(let (t4a : i64 (index-of "hello world" "world"))
     (t4b : i64 (index-of "hello world" "xyz"))
     (t4c : i64 (index-of "abcabc" "abc"))
     (t4d : i64 (index-of "hello" ""))
  (do (assert (= t4a 6)  "index-of: 'world' at index 6")
      (assert (= t4b -1) "index-of: 'xyz' not found")
      (assert (= t4c 0)  "index-of: first occurrence")
      (assert (= t4d 0)  "index-of: empty substring at 0")
      (print "index-of: PASS\n")))

;; ── to-lower ──
(let (t5a : String (to-lower "HELLO"))
     (t5b : String (to-lower "Hello World"))
     (t5c : String (to-lower "already lower"))
     (t5d : String (to-lower "ABC123!@#"))
  (do (assert (= t5a "hello")        "to-lower: all caps")
      (assert (= t5b "hello world")  "to-lower: mixed case")
      (assert (= t5c "already lower") "to-lower: already lowercase")
      (assert (= t5d "abc123!@#")    "to-lower: non-alpha unchanged")
      (print "to-lower: PASS\n")))

;; ── to-upper ──
(let (t6a : String (to-upper "hello"))
     (t6b : String (to-upper "Hello World"))
     (t6c : String (to-upper "ALREADY UPPER"))
     (t6d : String (to-upper "abc123!@#"))
  (do (assert (= t6a "HELLO")         "to-upper: all lower")
      (assert (= t6b "HELLO WORLD")   "to-upper: mixed case")
      (assert (= t6c "ALREADY UPPER") "to-upper: already uppercase")
      (assert (= t6d "ABC123!@#")     "to-upper: non-alpha unchanged")
      (print "to-upper: PASS\n")))

;; ── trim ──
(let (t7a : String (trim "  hello  "))
     (t7b : String (trim "\t\n hello \r\n"))
     (t7c : String (trim "no-spaces"))
     (t7d : String (trim "   "))
     (t7e : String (trim ""))
  (do (assert (= t7a "hello")     "trim: spaces both sides")
      (assert (= t7b "hello")     "trim: tabs, newlines, carriage returns")
      (assert (= t7c "no-spaces") "trim: nothing to trim")
      (assert (= t7d "")          "trim: all whitespace")
      (assert (= t7e "")          "trim: empty string")
      (print "trim: PASS\n")))

;; ── char-alpha ──
(let (t8a : bool (char-alpha "a"))
     (t8b : bool (char-alpha "Z"))
     (t8c : bool (char-alpha "5"))
     (t8d : bool (char-alpha " "))
     (t8e : bool (char-alpha ""))
  (do (assert (= t8a true)  "char-alpha: 'a' is alpha")
      (assert (= t8b true)  "char-alpha: 'Z' is alpha")
      (assert (= t8c false) "char-alpha: '5' is not alpha")
      (assert (= t8d false) "char-alpha: space is not alpha")
      (assert (= t8e false) "char-alpha: empty is not alpha")
      (print "char-alpha: PASS\n")))

;; ── char-digit ──
(let (t9a : bool (char-digit "0"))
     (t9b : bool (char-digit "9"))
     (t9c : bool (char-digit "a"))
     (t9d : bool (char-digit ""))
  (do (assert (= t9a true)  "char-digit: '0' is digit")
      (assert (= t9b true)  "char-digit: '9' is digit")
      (assert (= t9c false) "char-digit: 'a' is not digit")
      (assert (= t9d false) "char-digit: empty is not digit")
      (print "char-digit: PASS\n")))

;; ── char-whitespace ──
(let (t10a : bool (char-whitespace " "))
     (t10b : bool (char-whitespace "\t"))
     (t10c : bool (char-whitespace "\n"))
     (t10d : bool (char-whitespace "a"))
     (t10e : bool (char-whitespace ""))
  (do (assert (= t10a true)  "char-whitespace: space")
      (assert (= t10b true)  "char-whitespace: tab")
      (assert (= t10c true)  "char-whitespace: newline")
      (assert (= t10d false) "char-whitespace: 'a' is not whitespace")
      (assert (= t10e false) "char-whitespace: empty")
      (print "char-whitespace: PASS\n")))

;; ── Verify canonical names resolve to stdlib ──
(do (assert (= (starts-with "test-string" "test") true) "canonical: starts-with")
    (assert (= (ends-with "test-string" "string") true) "canonical: ends-with")
    (assert (= (contains "foobar" "oba") true) "canonical: contains")
    (assert (= (to-lower "FooBar") "foobar") "canonical: to-lower")
    (assert (= (to-upper "FooBar") "FOOBAR") "canonical: to-upper")
    (assert (= (trim "  hi  ") "hi") "canonical: trim")
    (print "canonical-names: PASS\n"))

(print "\nAll string byte-impl tests passed!\n")
