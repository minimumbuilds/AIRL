;; Test byte-based string implementations against Rust builtins
;; Each test compares the b- function (byte-based) with the builtin

;; ── starts-with ──
(let (t1a : bool (b-starts-with "hello world" "hello"))
     (t1b : bool (b-starts-with "hello world" "world"))
     (t1c : bool (b-starts-with "hello" "hello world"))
     (t1d : bool (b-starts-with "" ""))
     (t1e : bool (b-starts-with "abc" ""))
  (do (assert (= t1a true)  "b-starts-with: 'hello world' starts with 'hello'")
      (assert (= t1b false) "b-starts-with: 'hello world' does not start with 'world'")
      (assert (= t1c false) "b-starts-with: prefix longer than string")
      (assert (= t1d true)  "b-starts-with: empty string starts with empty")
      (assert (= t1e true)  "b-starts-with: any string starts with empty")
      (print "starts-with: PASS\n")))

;; ── ends-with ──
(let (t2a : bool (b-ends-with "hello world" "world"))
     (t2b : bool (b-ends-with "hello world" "hello"))
     (t2c : bool (b-ends-with "hello" "hello world"))
     (t2d : bool (b-ends-with "" ""))
     (t2e : bool (b-ends-with "abc" ""))
  (do (assert (= t2a true)  "b-ends-with: 'hello world' ends with 'world'")
      (assert (= t2b false) "b-ends-with: 'hello world' does not end with 'hello'")
      (assert (= t2c false) "b-ends-with: suffix longer than string")
      (assert (= t2d true)  "b-ends-with: empty string ends with empty")
      (assert (= t2e true)  "b-ends-with: any string ends with empty")
      (print "ends-with: PASS\n")))

;; ── contains ──
(let (t3a : bool (b-contains "hello world" "lo wo"))
     (t3b : bool (b-contains "hello world" "xyz"))
     (t3c : bool (b-contains "hello" "hello"))
     (t3d : bool (b-contains "abc" ""))
     (t3e : bool (b-contains "" "x"))
  (do (assert (= t3a true)  "b-contains: 'hello world' contains 'lo wo'")
      (assert (= t3b false) "b-contains: 'hello world' does not contain 'xyz'")
      (assert (= t3c true)  "b-contains: exact match")
      (assert (= t3d true)  "b-contains: any string contains empty")
      (assert (= t3e false) "b-contains: empty string contains nothing")
      (print "contains: PASS\n")))

;; ── index-of ──
(let (t4a : i64 (b-index-of "hello world" "world"))
     (t4b : i64 (b-index-of "hello world" "xyz"))
     (t4c : i64 (b-index-of "abcabc" "abc"))
     (t4d : i64 (b-index-of "hello" ""))
  (do (assert (= t4a 6)  "b-index-of: 'world' at index 6")
      (assert (= t4b -1) "b-index-of: 'xyz' not found")
      (assert (= t4c 0)  "b-index-of: first occurrence")
      (assert (= t4d 0)  "b-index-of: empty substring at 0")
      (print "index-of: PASS\n")))

;; ── to-lower ──
(let (t5a : String (b-to-lower "HELLO"))
     (t5b : String (b-to-lower "Hello World"))
     (t5c : String (b-to-lower "already lower"))
     (t5d : String (b-to-lower "ABC123!@#"))
  (do (assert (= t5a "hello")        "b-to-lower: all caps")
      (assert (= t5b "hello world")  "b-to-lower: mixed case")
      (assert (= t5c "already lower") "b-to-lower: already lowercase")
      (assert (= t5d "abc123!@#")    "b-to-lower: non-alpha unchanged")
      (print "to-lower: PASS\n")))

;; ── to-upper ──
(let (t6a : String (b-to-upper "hello"))
     (t6b : String (b-to-upper "Hello World"))
     (t6c : String (b-to-upper "ALREADY UPPER"))
     (t6d : String (b-to-upper "abc123!@#"))
  (do (assert (= t6a "HELLO")         "b-to-upper: all lower")
      (assert (= t6b "HELLO WORLD")   "b-to-upper: mixed case")
      (assert (= t6c "ALREADY UPPER") "b-to-upper: already uppercase")
      (assert (= t6d "ABC123!@#")     "b-to-upper: non-alpha unchanged")
      (print "to-upper: PASS\n")))

;; ── trim ──
(let (t7a : String (b-trim "  hello  "))
     (t7b : String (b-trim "\t\n hello \r\n"))
     (t7c : String (b-trim "no-spaces"))
     (t7d : String (b-trim "   "))
     (t7e : String (b-trim ""))
  (do (assert (= t7a "hello")     "b-trim: spaces both sides")
      (assert (= t7b "hello")     "b-trim: tabs, newlines, carriage returns")
      (assert (= t7c "no-spaces") "b-trim: nothing to trim")
      (assert (= t7d "")          "b-trim: all whitespace")
      (assert (= t7e "")          "b-trim: empty string")
      (print "trim: PASS\n")))

;; ── char-alpha ──
(let (t8a : bool (char-alpha "a"))
     (t8b : bool (char-alpha "Z"))
     (t8c : bool (char-alpha "5"))
     (t8d : bool (char-alpha " "))
     (t8e : bool (char-alpha ""))
  (do (assert (= t8a true)  "char-alpha: 'a' is alpha")
      (assert (= t8b true)  "char-alpha: 'Z' is alpha")
      (assert (= t8c false) "char-alpha: '5' is not alpha")
      (assert (= t8d false) "char-alpha: space is not alpha")
      (assert (= t8e false) "char-alpha: empty is not alpha")
      (print "char-alpha: PASS\n")))

;; ── char-digit ──
(let (t9a : bool (char-digit "0"))
     (t9b : bool (char-digit "9"))
     (t9c : bool (char-digit "a"))
     (t9d : bool (char-digit ""))
  (do (assert (= t9a true)  "char-digit: '0' is digit")
      (assert (= t9b true)  "char-digit: '9' is digit")
      (assert (= t9c false) "char-digit: 'a' is not digit")
      (assert (= t9d false) "char-digit: empty is not digit")
      (print "char-digit: PASS\n")))

;; ── char-whitespace ──
(let (t10a : bool (char-whitespace " "))
     (t10b : bool (char-whitespace "\t"))
     (t10c : bool (char-whitespace "\n"))
     (t10d : bool (char-whitespace "a"))
     (t10e : bool (char-whitespace ""))
  (do (assert (= t10a true)  "char-whitespace: space")
      (assert (= t10b true)  "char-whitespace: tab")
      (assert (= t10c true)  "char-whitespace: newline")
      (assert (= t10d false) "char-whitespace: 'a' is not whitespace")
      (assert (= t10e false) "char-whitespace: empty")
      (print "char-whitespace: PASS\n")))

;; ── Cross-validate against builtins ──
(let (bi-sw : bool (starts-with "test-string" "test"))
     (my-sw : bool (b-starts-with "test-string" "test"))
     (bi-ew : bool (ends-with "test-string" "string"))
     (my-ew : bool (b-ends-with "test-string" "string"))
     (bi-ct : bool (contains "foobar" "oba"))
     (my-ct : bool (b-contains "foobar" "oba"))
     (bi-tl : String (to-lower "FooBar"))
     (my-tl : String (b-to-lower "FooBar"))
     (bi-tu : String (to-upper "FooBar"))
     (my-tu : String (b-to-upper "FooBar"))
     (bi-tr : String (trim "  hi  "))
     (my-tr : String (b-trim "  hi  "))
  (do (assert (= bi-sw my-sw) "cross-validate: starts-with")
      (assert (= bi-ew my-ew) "cross-validate: ends-with")
      (assert (= bi-ct my-ct) "cross-validate: contains")
      (assert (= bi-tl my-tl) "cross-validate: to-lower")
      (assert (= bi-tu my-tu) "cross-validate: to-upper")
      (assert (= bi-tr my-tr) "cross-validate: trim")
      (print "cross-validate: PASS\n")))

(print "\nAll string byte-impl tests passed!\n")
