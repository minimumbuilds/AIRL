;; EXPECT: create:ok|sendrecv:ok|order:ok|timeout:ok
(let (ch : List (channel-new))
     (tx : i64 (at ch 0))
     (rx : i64 (at ch 1))
     (prop1 : String (if (>= tx 0) "ok" "FAIL:bad-handle"))
  (do (channel-send tx 42)
      (let (rr : _ (channel-recv rx))
           (prop2 : String (match rr (Ok v) (if (= v 42) "ok" (str "FAIL:val=" v)) (Err e) (str "FAIL:" e)))
        (do (channel-send tx 1)
            (channel-send tx 2)
            (channel-send tx 3)
            (let (m1 : _ (channel-recv rx))
                 (m2 : _ (channel-recv rx))
                 (m3 : _ (channel-recv rx))
                 (v1 : i64 (unwrap-or m1 0))
                 (v2 : i64 (unwrap-or m2 0))
                 (v3 : i64 (unwrap-or m3 0))
                 (prop3 : String (if (= v1 1) (if (= v2 2) (if (= v3 3) "ok" "FAIL:v3") "FAIL:v2") "FAIL:v1"))
                 (ch2 : List (channel-new))
                 (rx2 : i64 (at ch2 1))
                 (tr : _ (channel-recv-timeout rx2 10))
                 (prop4 : String (match tr (Ok _) "FAIL:should-timeout" (Err _) "ok"))
              (do (channel-close tx)
                  (channel-close rx)
                  (channel-close (at ch2 0))
                  (channel-close rx2)
                  (print (str "create:" prop1 "|sendrecv:" prop2 "|order:" prop3 "|timeout:" prop4))))))))
