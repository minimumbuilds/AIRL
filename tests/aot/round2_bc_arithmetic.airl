;; EXPECT: 1:100|2:50|3:30|4:3|5:1
(defn arith-test
  :sig [(a : i64) (b : i64) -> List]
  :requires [(valid a)]
  :ensures [(valid result)]
  :body [(+ a b) (- a b) (* a b) (/ a b) (% a b)])

(let (r1 : List (arith-test 75 25))
     (r2 : List (arith-test 10 3))
  (print (str "1:" (at r1 0)
              "|2:" (at r1 1)
              "|3:" (at r2 2)
              "|4:" (at r2 3)
              "|5:" (at r2 4))))
