;; EXPECT: int:42|str:hello|bool:true|sym:foo
;; DEPS: bootstrap/lexer.airl bootstrap/parser.airl
(match (lex "42")
  (Ok t1)
    (let (s1 : _ (at t1 0))
      (match (parse-atom s1)
        (Ok a1)
          (match a1
            (ASTInt v _ _)
              (match (lex "\"hello\"")
                (Ok t2)
                  (let (s2 : _ (at t2 0))
                    (match (parse-atom s2)
                      (Ok a2)
                        (match a2
                          (ASTStr v2 _ _)
                            (match (lex "true")
                              (Ok t3)
                                (let (s3 : _ (at t3 0))
                                  (match (parse-atom s3)
                                    (Ok a3)
                                      (match a3
                                        (ASTBool v3 _ _)
                                          (match (lex "foo")
                                            (Ok t4)
                                              (let (s4 : _ (at t4 0))
                                                (match (parse-atom s4)
                                                  (Ok a4)
                                                    (match a4
                                                      (ASTSymbol name _ _)
                                                        (print (str "int:" v "|str:" v2 "|bool:" v3 "|sym:" name))
                                                      _ (print "not symbol"))
                                                  (Err e) (print (str "err: " e))))
                                            (Err e) (print (str "err: " e)))
                                        _ (print "not bool"))
                                    (Err e) (print (str "err: " e))))
                              (Err e) (print (str "err: " e)))
                          _ (print "not string"))
                      (Err e) (print (str "err: " e))))
                (Err e) (print (str "err: " e)))
            _ (print "not int"))
        (Err e) (print (str "err: " e))))
  (Err e) (print (str "err: " e)))
