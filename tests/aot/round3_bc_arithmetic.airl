;; EXPECT: 1:100|2:50|3:30|4:13|5:7|6:0|7:0|8:1000000|9:-1|10:0
(defn safe-arith
  :sig [(a : i64) (b : i64) -> List]
  :requires [(valid a)]
  :ensures [(valid result)]
  :body [(+ a b) (- a b) (* a b)])

;; 5 passing from R2
(let (r1 : List (safe-arith 75 25))
     (r2 : List (safe-arith 10 3))
     ;; 5 edge cases
     (r3 : i64 (+ 0 0))
     (r4 : i64 (- 0 0))
     (r5 : i64 (* 1000 1000))
     (r6 : i64 (+ -1 0))
     (r7 : i64 (* 0 999999))
  (print (str "1:" (at r1 0) "|2:" (at r1 1) "|3:" (at r2 2) "|4:" (at r2 0) "|5:" (at r2 1)
              "|6:" r3 "|7:" r4 "|8:" r5 "|9:" r6 "|10:" r7)))
