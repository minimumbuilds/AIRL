;; EXPECT: 1:1|2:1|3:2|4:6|5:24|6:120|7:720|8:5040|9:40320|10:362880
(defn fact :verify checked
  :sig [(n : i64) -> i64]
  :requires [(valid n)]
  :ensures [(valid result)]
  :body (if (<= n 1) 1 (* n (fact (- n 1)))))

;; 5 passing from R2 + 5 larger inputs
(print (str "1:" (fact 0)
            "|2:" (fact 1)
            "|3:" (fact 2)
            "|4:" (fact 3)
            "|5:" (fact 4)
            "|6:" (fact 5)
            "|7:" (fact 6)
            "|8:" (fact 7)
            "|9:" (fact 8)
            "|10:" (fact 9)))
