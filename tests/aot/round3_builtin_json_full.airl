;; EXPECT: int:ok|str:ok|bool:ok|null:ok|roundtrip-int:ok|roundtrip-str:ok|stringify-list:ok
(let (p1 : _ (json-parse "42"))
     (prop1 : String (match p1 (Ok v) (if (= v 42) "ok" (str "FAIL:v=" v)) (Err e) (str "FAIL:" e)))
     (p2 : _ (json-parse "\"hello\""))
     (prop2 : String (match p2 (Ok v) (if (= v "hello") "ok" (str "FAIL:" v)) (Err e) (str "FAIL:" e)))
     (p3 : _ (json-parse "true"))
     (prop3 : String (match p3 (Ok v) (if (= v true) "ok" (str "FAIL:" v)) (Err e) (str "FAIL:" e)))
     (p4 : _ (json-parse "null"))
     (prop4 : String (match p4 (Ok v) (if (= v nil) "ok" (str "FAIL:" v)) (Err e) (str "FAIL:" e)))
     (s1 : String (json-stringify 99))
     (p5 : _ (json-parse s1))
     (prop5 : String (match p5 (Ok v) (if (= v 99) "ok" (str "FAIL:" v)) (Err e) (str "FAIL:" e)))
     (s2 : String (json-stringify "world"))
     (p6 : _ (json-parse s2))
     (prop6 : String (match p6 (Ok v) (if (= v "world") "ok" (str "FAIL:" v)) (Err e) (str "FAIL:" e)))
     (s3 : String (json-stringify [1 2 3]))
     (prop7 : String (if (contains s3 "1") "ok" "FAIL:no-1"))
  (print (str "int:" prop1 "|str:" prop2 "|bool:" prop3 "|null:" prop4 "|roundtrip-int:" prop5 "|roundtrip-str:" prop6 "|stringify-list:" prop7)))
