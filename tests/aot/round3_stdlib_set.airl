;; EXPECT: new:0|from:3|add:1|remove:2|contains:t f|size:3|union:4|inter:1|diff:2|subset:t f|equal:t f
(let (s0 : _ (set-new))
     (s1 : _ (set-from ["a" "b" "c"]))
     (s2 : _ (set-add s0 "x"))
     (s3 : _ (set-remove s1 "b"))
     (c1 : Bool (set-contains? s1 "a"))
     (c2 : Bool (set-contains? s1 "z"))
     (sz : i64 (set-size s1))
     (su : _ (set-union s1 (set-from ["c" "d"])))
     (si : _ (set-intersection s1 (set-from ["b" "d"])))
     (sd : _ (set-difference s1 (set-from ["a"])))
     (ss1 : Bool (set-subset? (set-from ["a" "b"]) s1))
     (ss2 : Bool (set-subset? s1 (set-from ["a"])))
     (eq1 : Bool (set-equal? s1 (set-from ["c" "b" "a"])))
     (eq2 : Bool (set-equal? s1 (set-from ["a" "b"])))
  (print (str "new:" (set-size s0)
              "|from:" (set-size s1)
              "|add:" (set-size s2)
              "|remove:" (set-size s3)
              "|contains:" (if c1 "t" "f") " " (if c2 "t" "f")
              "|size:" sz
              "|union:" (set-size su)
              "|inter:" (set-size si)
              "|diff:" (set-size sd)
              "|subset:" (if ss1 "t" "f") " " (if ss2 "t" "f")
              "|equal:" (if eq1 "t" "f") " " (if eq2 "t" "f"))))
