;; EXPECT: fold:15|map:6|filter:9|recurse:55
;; Regression test: TailCall-optimized stdlib functions inside spawned threads.
;; Previously segfaulted because bc-compile-function-with-contracts used
;; bc-compile-expr instead of bc-compile-expr-tail, so nested lambdas inside
;; tail-compiled functions were lost.
(let (h1 : i64 (thread-spawn (fn [] (fold (fn [a x] (+ a x)) 0 [1 2 3 4 5]))))
     (h2 : i64 (thread-spawn (fn [] (length (map (fn [x] (* x x)) [1 2 3 4 5 6])))))
     (h3 : i64 (thread-spawn (fn [] (fold (fn [a x] (+ a x)) 0 (filter (fn [x] (> x 3)) [1 2 3 4 5])))))
     (h4 : i64 (thread-spawn (fn [] (fold (fn [a i] (+ a i)) 0 (range 1 11)))))
     (r1 : _ (thread-join h1))
     (r2 : _ (thread-join h2))
     (r3 : _ (thread-join h3))
     (r4 : _ (thread-join h4))
     (v1 : String (match r1 (Ok v) (str v) (Err e) (str "ERR:" e)))
     (v2 : String (match r2 (Ok v) (str v) (Err e) (str "ERR:" e)))
     (v3 : String (match r3 (Ok v) (str v) (Err e) (str "ERR:" e)))
     (v4 : String (match r4 (Ok v) (str v) (Err e) (str "ERR:" e)))
  (print (str "fold:" v1 "|map:" v2 "|filter:" v3 "|recurse:" v4)))
