;; EXPECT: 8|2|-15|3|1|true|false|true|false
(let (a : i64 (+ 3 5))
     (b : i64 (- 7 5))
     (c : i64 (* 3 -5))
     (d : i64 (/ 10 3))
     (e : i64 (% 7 3))
     (f : Bool (= 5 5))
     (g : Bool (= 5 6))
     (h : Bool (< 3 5))
     (i : Bool (> 3 5))
  (print (str a "|" b "|" c "|" d "|" e "|" f "|" g "|" h "|" i)))
