;; Test: Pure AIRL path functions (Spec 06/07)
;;
;; Rust builtins deregistered — using canonical names.

;; ── Helper: last-index-of ──
(defn last-index-of
  :sig [(haystack : String) (needle : String) -> Int]
  :requires [(valid haystack) (valid needle)]
  :ensures [(>= result -1)]
  :body
    (let (parts : List (split haystack needle))
      (if (<= (length parts) 1)
        -1
        (- (- (length haystack) (length (at parts (- (length parts) 1)))) (length needle)))))

;; ── path-join ──
(defn path-join
  :sig [(a : String) (b : String) -> String]
  :requires [(valid a) (valid b)]
  :ensures [(valid result)]
  :body
    (if (= a "")
      b
      (if (= b "")
        a
        (if (= (substring a (- (length a) 1) (length a)) "/")
          (+ a b)
          (+ (+ a "/") b)))))

;; ── path-parent ──
(defn path-parent
  :sig [(path : String) -> String]
  :requires [(valid path)]
  :ensures [(valid result)]
  :body
    (let (idx : Int (last-index-of path "/"))
      (if (= idx -1)
        ""
        (if (= idx 0)
          "/"
          (substring path 0 idx)))))

;; ── path-filename ──
(defn path-filename
  :sig [(path : String) -> String]
  :requires [(valid path)]
  :ensures [(valid result)]
  :body
    (let (idx : Int (last-index-of path "/"))
      (if (= idx -1)
        path
        (substring path (+ idx 1) (length path)))))

;; ── path-extension ──
(defn path-extension
  :sig [(path : String) -> String]
  :requires [(valid path)]
  :ensures [(valid result)]
  :body
    (let (fname : String (path-filename path))
      (let (idx : Int (last-index-of fname "."))
        (if (= idx -1)
          ""
          (if (= idx 0)
            ""
            (substring fname (+ idx 1) (length fname)))))))

;; ── is-absolute ──
(defn is-absolute
  :sig [(path : String) -> Bool]
  :requires [(valid path)]
  :ensures [(valid result)]
  :body (starts-with path "/"))


;; ═══════════════════════════════════════════════
;; Tests
;; ═══════════════════════════════════════════════

;; ── path-join tests ──
(if (= (path-join "foo" "bar") "foo/bar")
  (println "PASS: path-join basic")
  (println "FAIL: path-join basic"))

(if (= (path-join "foo/" "bar") "foo/bar")
  (println "PASS: path-join trailing slash")
  (println "FAIL: path-join trailing slash"))

(if (= (path-join "" "bar") "bar")
  (println "PASS: path-join empty first")
  (println "FAIL: path-join empty first"))

(if (= (path-join "foo" "") "foo")
  (println "PASS: path-join empty second")
  (println "FAIL: path-join empty second"))

;; ── path-parent tests ──
(if (= (path-parent "/home/user/file.txt") "/home/user")
  (println "PASS: path-parent absolute")
  (println "FAIL: path-parent absolute"))

(if (= (path-parent "foo/bar.txt") "foo")
  (println "PASS: path-parent relative")
  (println "FAIL: path-parent relative"))

(if (= (path-parent "file.txt") "")
  (println "PASS: path-parent no parent")
  (println "FAIL: path-parent no parent"))

(if (= (path-parent "/file.txt") "/")
  (println "PASS: path-parent root")
  (println "FAIL: path-parent root"))

;; ── path-filename tests ──
(if (= (path-filename "/home/user/file.txt") "file.txt")
  (println "PASS: path-filename absolute")
  (println "FAIL: path-filename absolute"))

(if (= (path-filename "file.txt") "file.txt")
  (println "PASS: path-filename no dir")
  (println "FAIL: path-filename no dir"))

(if (= (path-filename "foo/bar/baz.rs") "baz.rs")
  (println "PASS: path-filename nested")
  (println "FAIL: path-filename nested"))

;; ── path-extension tests ──
(if (= (path-extension "/home/user/file.txt") "txt")
  (println "PASS: path-extension basic")
  (println "FAIL: path-extension basic"))

(if (= (path-extension "archive.tar.gz") "gz")
  (println "PASS: path-extension double ext")
  (println "FAIL: path-extension double ext"))

(if (= (path-extension "Makefile") "")
  (println "PASS: path-extension no ext")
  (println "FAIL: path-extension no ext"))

(if (= (path-extension ".gitignore") "")
  (println "PASS: path-extension dotfile")
  (println "FAIL: path-extension dotfile"))

;; ── is-absolute tests ──
(if (is-absolute "/usr/bin")
  (println "PASS: is-absolute true")
  (println "FAIL: is-absolute true"))

(if (not (is-absolute "relative/path"))
  (println "PASS: is-absolute false")
  (println "FAIL: is-absolute false"))

(if (not (is-absolute ""))
  (println "PASS: is-absolute empty")
  (println "FAIL: is-absolute empty"))

;; ── last-index-of edge cases ──
(if (= (last-index-of "abcabc" "c") 5)
  (println "PASS: last-index-of found last")
  (println "FAIL: last-index-of found last"))

(if (= (last-index-of "abc" "z") -1)
  (println "PASS: last-index-of not found")
  (println "FAIL: last-index-of not found"))

(println "path tests complete")
