;; EXPECT: echo:ok|true:ok|false:ok|args:ok
;; REQUIRES_ENV: AIRL_ALLOW_EXEC=echo,true,false
(let (r1 : _ (shell-exec "echo" ["hello"]))
     (prop1 : String (match r1 (Ok m) (if (contains (map-get m "stdout") "hello") "ok" "FAIL:no-hello") (Err e) (str "FAIL:" e)))
     (r2 : _ (shell-exec "true" []))
     (prop2 : String (match r2 (Ok m) (if (= (map-get m "exit-code") 0) "ok" (str "FAIL:exit")) (Err e) (str "FAIL:" e)))
     (r3 : _ (shell-exec "false" []))
     (prop3 : String (match r3 (Ok m) (if (!= (map-get m "exit-code") 0) "ok" "FAIL:should-fail") (Err e) (str "FAIL:" e)))
     (r4 : _ (shell-exec "echo" ["-n" "abc"]))
     (prop4 : String (match r4 (Ok m) (if (contains (map-get m "stdout") "abc") "ok" "FAIL:no-abc") (Err e) (str "FAIL:" e)))
  (print (str "echo:" prop1 "|true:" prop2 "|false:" prop3 "|args:" prop4)))
