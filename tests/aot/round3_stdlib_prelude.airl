;; EXPECT: map:2 4 6|filter:4 5|fold:15|rev:3 2 1|concat:1 2 3 4|zip:2|flat:1 2 3 4|range:0 1 2|take:1 2|drop:3 4 5|any:t|all:f|find:3|sort:1 2 3|unique:1 2 3|enum:0-a 1-b|group:2
(let (xs : List [1 2 3 4 5])
     (m1 : List (map (fn [x] (* x 2)) [1 2 3]))
     (f1 : List (filter (fn [x] (> x 3)) xs))
     (s1 : i64 (fold (fn [a x] (+ a x)) 0 xs))
     (rv : List (reverse [1 2 3]))
     (cn : List (concat [1 2] [3 4]))
     (zp : List (zip [1 2] [3 4]))
     (fl : List (flatten [[1 2] [3 4]]))
     (rg : List (range 0 3))
     (tk : List (take 2 xs))
     (dr : List (drop 2 xs))
     (an : Bool (any (fn [x] (> x 4)) xs))
     (al : Bool (all (fn [x] (> x 0)) [1 2 -1]))
     (fn1 : _ (find (fn [x] (> x 2)) xs))
     (sr : List (sort (fn [a b] (< a b)) [3 1 2]))
     (uq : List (unique [1 2 3 2 1]))
     (en : List (enumerate ["a" "b"]))
     (gr : _ (group-by (fn [x] (if (> x 2) "big" "small")) xs))
  (print (str "map:" (at m1 0) " " (at m1 1) " " (at m1 2)
              "|filter:" (at f1 0) " " (at f1 1)
              "|fold:" s1
              "|rev:" (at rv 0) " " (at rv 1) " " (at rv 2)
              "|concat:" (at cn 0) " " (at cn 1) " " (at cn 2) " " (at cn 3)
              "|zip:" (length zp)
              "|flat:" (at fl 0) " " (at fl 1) " " (at fl 2) " " (at fl 3)
              "|range:" (at rg 0) " " (at rg 1) " " (at rg 2)
              "|take:" (at tk 0) " " (at tk 1)
              "|drop:" (at dr 0) " " (at dr 1) " " (at dr 2)
              "|any:" (if an "t" "f")
              "|all:" (if al "t" "f")
              "|find:" fn1
              "|sort:" (at sr 0) " " (at sr 1) " " (at sr 2)
              "|unique:" (at uq 0) " " (at uq 1) " " (at uq 2)
              "|enum:" (at (at en 0) 0) "-" (at (at en 0) 1) " " (at (at en 1) 0) "-" (at (at en 1) 1)
              "|group:" (map-size gr))))
