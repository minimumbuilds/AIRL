;; EXPECT: entries:2|fromE:1|merge:3|mapvals:20 40|filter:1|update:10|updateor:100|count:1
(let (m1 : _ (map-from ["a" 10 "b" 20]))
     (e1 : List (map-entries m1))
     (m2 : _ (map-from-entries [["c" 30]]))
     (mg : _ (map-merge m1 m2))
     (mv : _ (map-map-values (fn [v] (* v 2)) m1))
     (mf : _ (map-filter (fn [k v] (> v 15)) m1))
     (mu : _ (map-update m1 "a" (fn [v] (+ v 0))))
     (mo : _ (map-update-or m1 "z" 99 (fn [v] (+ v 1))))
     (mc : i64 (map-count (fn [k v] (> v 15)) m1))
  (print (str "entries:" (length e1)
              "|fromE:" (map-size m2)
              "|merge:" (map-size mg)
              "|mapvals:" (map-get mv "a") " " (map-get mv "b")
              "|filter:" (map-size mf)
              "|update:" (map-get mu "a")
              "|updateor:" (map-get mo "z")
              "|count:" mc)))
