;; EXPECT: echo:hello|send-err:tcp-send|recv-err:tcp-recv|exact-err:tcp-recv-exact
;; Test: TCP operations from spawned threads (deadlock regression)
;; Also tests error paths for invalid handles.
(let (port : i64 19887)
     ;; Start echo server in a thread
     (srv : i64 (thread-spawn (fn []
       (match (tcp-listen port 1)
         (Ok server) (do
           (match (tcp-accept server)
             (Ok conn) (do
               (match (tcp-recv conn 1024)
                 (Ok data) (do (tcp-send conn data) nil)
                 (Err _) nil)
               (sleep 100)
               (tcp-close conn))
             (Err _) nil)
           (tcp-close server))
         (Err _) nil)))))
     (_ : _ (sleep 200))
     ;; Connect from main thread
     (conn-r : _ (tcp-connect "127.0.0.1" port))
  (match conn-r
    (Ok conn) (let
      ;; Test 1: tcp-send from spawned thread (was deadlocking)
      (h1 : i64 (thread-spawn (fn []
        (let (payload : List (bytes-from-string "hello"))
          (match (tcp-send conn payload)
            (Ok _) (match (tcp-recv conn 1024)
              (Ok data) (bytes-to-string data 0 (length data))
              (Err e) (str "recv-err:" e))
            (Err e) (str "send-err:" e))))))
      (r1 : _ (thread-join h1))
      (v1 : String (match r1 (Ok v) (str v) (Err e) (str "ERR:" e)))
      ;; Test 2: tcp-send with invalid handle (should error, not crash)
      (h2 : i64 (thread-spawn (fn []
        (match (tcp-send 99999 (bytes-from-string "x"))
          (Ok _) "unexpected-ok"
          (Err e) (if (contains e "tcp-send") "tcp-send" (str "wrong-err:" e))))))
      (r2 : _ (thread-join h2))
      (v2 : String (match r2 (Ok v) (str v) (Err e) (str "ERR:" e)))
      ;; Test 3: tcp-recv with invalid handle
      (h3 : i64 (thread-spawn (fn []
        (match (tcp-recv 99998 1024)
          (Ok _) "unexpected-ok"
          (Err e) (if (contains e "tcp-recv") "tcp-recv" (str "wrong-err:" e))))))
      (r3 : _ (thread-join h3))
      (v3 : String (match r3 (Ok v) (str v) (Err e) (str "ERR:" e)))
      ;; Test 4: tcp-recv-exact with invalid handle
      (h4 : i64 (thread-spawn (fn []
        (match (tcp-recv-exact 99997 10)
          (Ok _) "unexpected-ok"
          (Err e) (if (contains e "tcp-recv-exact") "tcp-recv-exact" (str "wrong-err:" e))))))
      (r4 : _ (thread-join h4))
      (v4 : String (match r4 (Ok v) (str v) (Err e) (str "ERR:" e)))
      ;; Cleanup
      (_ : _ (tcp-close conn))
      (_ : _ (thread-join srv))
      (do (print (str "echo:" v1 "|send-err:" v2 "|recv-err:" v3 "|exact-err:" v4))))
    (Err e) (print (str "connect err: " e))))
