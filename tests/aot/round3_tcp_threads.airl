;; EXPECT: echo:hello|send-err:invalid handle|recv-err:invalid handle|exact-err:invalid handle
;; Test: TCP operations from spawned threads with nested match patterns.
(defn run-server
  :sig [(port : i64) -> Nil]
  :requires [(> port 0)]
  :ensures [(valid result)]
  :body (match (tcp-listen port 1)
    (Ok server) (do
      (match (tcp-accept server)
        (Ok conn) (do
          (match (tcp-recv conn 1024)
            (Ok data) (do (tcp-send conn data) nil)
            (Err _) nil)
          (sleep 100)
          (tcp-close conn))
        (Err _) nil)
      (tcp-close server))
    (Err _) nil))

(defn test-send-in-thread
  :sig [(conn : i64) -> String]
  :requires [(valid conn)]
  :ensures [(valid result)]
  :body
    (let (payload : List (bytes-from-string "hello"))
      (match (tcp-send conn payload)
        (Ok _) (match (tcp-recv conn 1024)
          (Ok data) (bytes-to-string data 0 (length data))
          (Err e) (str "recv-err:" e))
        (Err e) (str "send-err:" e))))

(defn test-send-invalid
  :sig [-> String]
  :requires [(valid 1)]
  :ensures [(valid result)]
  :body (match (tcp-send 99999 (bytes-from-string "x"))
    (Ok _) "unexpected-ok"
    (Err e) (str e)))

(defn test-recv-invalid
  :sig [-> String]
  :requires [(valid 1)]
  :ensures [(valid result)]
  :body (match (tcp-recv 99998 1024)
    (Ok _) "unexpected-ok"
    (Err e) (str e)))

(defn test-recv-exact-invalid
  :sig [-> String]
  :requires [(valid 1)]
  :ensures [(valid result)]
  :body (match (tcp-recv-exact 99997 10)
    (Ok _) "unexpected-ok"
    (Err e) (str e)))

(let (port : i64 19896)
     (srv : i64 (thread-spawn (fn [] (run-server port))))
     (_ : _ (sleep 200))
     (conn-r : _ (tcp-connect "127.0.0.1" port))
  (match conn-r
    (Ok conn)
      (let (h1 : i64 (thread-spawn (fn [] (test-send-in-thread conn))))
           (r1 : _ (thread-join h1))
           (v1 : String (match r1 (Ok v) (str v) (Err e) (str "ERR:" e)))
           (h2 : i64 (thread-spawn (fn [] (test-send-invalid))))
           (r2 : _ (thread-join h2))
           (v2 : String (match r2 (Ok v) (str v) (Err e) (str "ERR:" e)))
           (h3 : i64 (thread-spawn (fn [] (test-recv-invalid))))
           (r3 : _ (thread-join h3))
           (v3 : String (match r3 (Ok v) (str v) (Err e) (str "ERR:" e)))
           (h4 : i64 (thread-spawn (fn [] (test-recv-exact-invalid))))
           (r4 : _ (thread-join h4))
           (v4 : String (match r4 (Ok v) (str v) (Err e) (str "ERR:" e)))
           (_ : _ (tcp-close conn))
           (_ : _ (thread-join srv))
        (print (str "echo:" v1 "|send-err:" v2 "|recv-err:" v3 "|exact-err:" v4)))
    (Err e) (print (str "connect err: " e))))
