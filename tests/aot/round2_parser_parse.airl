;; EXPECT: 1:1|2:1|3:2|4:1|5:1
;; DEPS: bootstrap/lexer.airl bootstrap/parser.airl
(defn count-top
  :sig [(src : String) -> i64]
  :requires [(valid src)]
  :ensures [(valid result)]
  :body
    (match (parse src)
      (Ok ast) (length ast)
      (Err _) -1))

(print (str "1:" (count-top "(+ 1 2)")
            "|2:" (count-top "(if true 1 2)")
            "|3:" (count-top "(defn f :sig [(x : i64) -> i64] :requires [(valid x)] :ensures [(valid result)] :body x) (f 1)")
            "|4:" (count-top "(let (x : i64 5) (+ x 1))")
            "|5:" (count-top "(match (Ok 42) (Ok v) v (Err e) 0)")))
