;; EXPECT: isok:t f|iserr:f t|unwrap:42 0|mapok:43|maperr:FAIL|andthen:ok|orelse:99|okor:ok-hi
(let (ok1 : _ (Ok 42))
     (er1 : _ (Err "fail"))
     (r1 : Bool (is-ok? ok1))
     (r2 : Bool (is-ok? er1))
     (r3 : Bool (is-err? ok1))
     (r4 : Bool (is-err? er1))
     (r5 : i64 (unwrap-or ok1 0))
     (r6 : i64 (unwrap-or er1 0))
     (r7 : _ (map-ok (fn [x] (+ x 1)) ok1))
     (r8 : _ (map-err (fn [e] (to-upper e)) er1))
     (r9 : _ (and-then (fn [x] (Ok "ok")) ok1))
     (r10 : _ (or-else (fn [e] (Ok 99)) er1))
     (r11 : _ (ok-or "hi" "default"))
  (print (str "isok:" (if r1 "t" "f") " " (if r2 "t" "f")
              "|iserr:" (if r3 "t" "f") " " (if r4 "t" "f")
              "|unwrap:" r5 " " r6
              "|mapok:" (unwrap-or r7 0)
              "|maperr:" (match r8 (Ok _) "?" (Err e) e)
              "|andthen:" (unwrap-or r9 "?")
              "|orelse:" (unwrap-or r10 0)
              "|okor:" (match r11 (Ok v) (str "ok-" v) (Err e) (str "err-" e)))))
