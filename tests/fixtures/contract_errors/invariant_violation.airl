;; ERROR: contract violated
;; The invariant (> result 0) is violated when x = 0
(defn must-be-positive :verify checked
  :sig [(x : i64) -> i64]
  :intent "Identity function with positive invariant"
  :requires [(valid x)]
  :ensures [(valid result)]
  :invariant [(> result 0)]
  :body x)
(must-be-positive 0)
