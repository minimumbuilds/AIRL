;; EXPECT: "channel-send: invalid sender handle 5"
;; Closed channel returns "invalid sender handle" error
(let (ch : List (channel-new))
     (tx : i64 (at ch 0))
     (rx : i64 (at ch 1))
  (do
    (channel-close tx)
    (match (channel-send tx "hello")
      (Ok _) "unexpected ok"
      (Err e) e)))
