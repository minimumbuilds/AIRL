;; EXPECT: true
;; Smoke test for the builtins the self-hosted lexer depends on.
;; The full lexer tests are in bootstrap/lexer_test.airl (run via cargo run -- run).
;; Fixtures can't load external files, so we test the underlying primitives here.
(do
  (let (src : String "(+ 1 2)")
       (ch : String (char-at src 0))
       (is-paren : Bool (= ch "("))
       (is-digit : Bool (contains "0123456789" (char-at src 3)))
       (digit-val : i64 (index-of "0123456789" (char-at src 3)))
       (sub : String (substring src 1 2))
    (if is-paren
      (if is-digit
        (if (= digit-val 1)
          (= sub "+")
          false)
        false)
      false)))
