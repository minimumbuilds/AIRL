;; EXPECT: ()
;; End-to-end tests for float math builtins

;; sqrt
(print "sqrt 4.0:" (sqrt (int-to-float 4)))
(assert (= (sqrt 4.0) 2.0) "sqrt(4.0) should be 2.0")

;; floor / ceil / round
(print "floor 3.7:" (floor 3.7))
(assert (= (floor 3.7) 3) "floor(3.7) should be 3")
(print "ceil 3.2:" (ceil 3.2))
(assert (= (ceil 3.2) 4) "ceil(3.2) should be 4")
(print "round 3.5:" (round 3.5))
(assert (= (round 3.5) 4) "round(3.5) should be 4")

;; trig at zero
(assert (= (sin 0.0) 0.0) "sin(0) should be 0")
(assert (= (cos 0.0) 1.0) "cos(0) should be 1")
(assert (= (tan 0.0) 0.0) "tan(0) should be 0")

;; log / exp
(assert (= (log 1.0) 0.0) "log(1) should be 0")
(assert (= (exp 0.0) 1.0) "exp(0) should be 1")

;; conversions
(assert (= (float-to-int 3.14) 3) "float-to-int(3.14) should be 3")
(assert (= (int-to-float 3) 3.0) "int-to-float(3) should be 3.0")

;; NaN and infinity
(print "is-nan? (nan):" (is-nan? (nan)))
(assert (is-nan? (nan)) "nan should be NaN")
(assert (not (is-nan? 1.0)) "1.0 should not be NaN")

(print "is-infinite? (infinity):" (is-infinite? (infinity)))
(assert (is-infinite? (infinity)) "infinity should be infinite")
(assert (not (is-infinite? 1.0)) "1.0 should not be infinite")

(print "All float math tests passed")
