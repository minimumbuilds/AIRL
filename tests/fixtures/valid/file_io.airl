;; EXPECT: "append OK size OK isdir OK readdir OK rename OK delete OK ALL PASSED"
;; Test file I/O builtins — returns result string (fixture runner checks return value, not stdout)
;; Uses temp-dir to ensure a unique, clean directory per run (fixes non-hermetic readdir test).

(let (dir : String (temp-dir "airl-file-io-test"))
  (let (logfile : String (str dir "/log.txt"))
    (let (renamedfile : String (str dir "/renamed.txt"))
      (do
        (write-file logfile "line1\n")
        (append-file logfile "line2\n")

        (let (r1 : String (let (content : String (read-file logfile))
                             (if (contains content "line2") "append OK " "append FAIL ")))
             (r2 : String (let (sz : i64 (file-size logfile))
                             (if (> sz 0) "size OK " "size FAIL ")))
             (r3 : String (if (is-dir? dir) "isdir OK " "isdir FAIL "))
             (r4 : String (let (entries : List (read-dir dir))
                             (if (= (length entries) 1) "readdir OK " "readdir FAIL ")))
          (do
            (rename-file logfile renamedfile)
            (let (r5 : String (if (file-exists? renamedfile) "rename OK " "rename FAIL "))
              (do
                (delete-file renamedfile)
                (let (r6 : String (if (not (file-exists? renamedfile)) "delete OK " "delete FAIL "))
                  (do
                    (delete-dir dir)
                    (str r1 r2 r3 r4 r5 r6 "ALL PASSED")))))))))))
