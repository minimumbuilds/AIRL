;; EXPECT: 15
;; Test Z3 verification of let-bindings in contract clauses.
;;Z3-PROVEN: sum-of-three
(defn sum-of-three
  :sig [(a : i32) (b : i32) (c : i32) -> i32]
  :intent "add three numbers"
  :ensures [(= result (+ a (+ b c)))]
  :body (let (ab : i32 (+ a b))
          (+ ab c)))
(sum-of-three 3 5 7)
