;; LLM-generated AIRL: intentionally violates a contract
;; Tests that the runtime catches the violation

(defn positive-only
  :sig [(x : i64) -> i64]
  :intent "Returns x, but requires it to be positive"
  :requires [(> x 0)]
  :ensures [(> result 0)]
  :body x)

;; This should succeed
(positive-only 42)
