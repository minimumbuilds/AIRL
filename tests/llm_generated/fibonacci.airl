;; LLM-generated AIRL program: Fibonacci-like computation
;; Generated by Claude Opus 4.6 as a test of AI-to-AI communication

(defn square
  :sig [(x : i64) -> i64]
  :intent "Compute x squared"
  :requires [(valid x)]
  :ensures [(= result (* x x))]
  :body (* x x))

(defn sum-of-squares
  :sig [(a : i64) (b : i64) -> i64]
  :intent "Sum of squares of two numbers"
  :requires [(valid a) (valid b)]
  :ensures [(= result (+ (square a) (square b)))]
  :body (+ (square a) (square b)))

(defn abs-diff
  :sig [(a : i64) (b : i64) -> i64]
  :intent "Absolute difference"
  :requires [(valid a) (valid b)]
  :ensures [(>= result 0)]
  :body (if (> a b) (- a b) (- b a)))

(defn clamp
  :sig [(x : i64) (lo : i64) (hi : i64) -> i64]
  :intent "Clamp x to range [lo, hi]"
  :requires [(valid x) (valid lo) (valid hi) (<= lo hi)]
  :ensures [(>= result lo) (<= result hi)]
  :body (if (< x lo) lo (if (> x hi) hi x)))

;; Run the computations
(let (a : i64 (square 5))
  (let (b : i64 (sum-of-squares 3 4))
    (let (c : i64 (abs-diff a b))
      (clamp c 0 10))))
