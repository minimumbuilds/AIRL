;; LLM-generated orchestrator
;; Spawns the worker, dispatches typed tasks, validates results

(let (worker : String (spawn-agent "tests/llm_generated/llm_worker.airl"))
     (grade1 : i64 (send worker "classify" 85))
     (grade2 : i64 (send worker "classify" 95))
     (avg : i64 (send worker "weighted-average" 85 95 60))
  (send worker "classify" avg))
