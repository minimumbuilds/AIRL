;; ── Crypto Stdlib Tests ──────────────────
;; SHA-256, HMAC-SHA-256, PBKDF2-HMAC-SHA-256

;; ── SHA-256 ──

(assert-eq (b-sha256 "")
           "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
           "sha256 empty string")

(assert-eq (b-sha256 "abc")
           "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
           "sha256 abc")

(assert-eq (b-sha256 "hello")
           "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"
           "sha256 hello")

(assert-eq (b-sha256 "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
           "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1"
           "sha256 two-block")

(assert-eq (b-sha256 "The quick brown fox jumps over the lazy dog")
           "d7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592"
           "sha256 fox")

;; ── HMAC-SHA-256 ──

(assert-eq (b-hmac-sha256 "Jefe" "what do ya want for nothing?")
           "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843"
           "hmac-sha256 rfc4231 tc2")

(assert-eq (b-hmac-sha256 "key" "The quick brown fox jumps over the lazy dog")
           "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8"
           "hmac-sha256 fox")

;; ── PBKDF2-HMAC-SHA-256 ──

(assert-eq (b-pbkdf2-sha256 "password" "salt" 1 32)
           "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b"
           "pbkdf2-sha256 c=1")

(assert-eq (b-pbkdf2-sha256 "password" "salt" 2 32)
           "ae4d0c95af6b46d32d0adff928f06dd02a303f8ef3c251dfd6e2d85a95474c43"
           "pbkdf2-sha256 c=2")

(println "All crypto tests passed")
