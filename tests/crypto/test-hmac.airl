;; ── HMAC-SHA-256 Test Vectors ──

;; RFC 4231 Test Case 2
(assert-eq (b-hmac-sha256 "Jefe" "what do ya want for nothing?")
           "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843"
           "hmac-sha256 rfc4231 tc2")

;; RFC 4231 Test Case 1 (key = 0x0b * 20, data = "Hi There")
;; Key needs to be constructed from bytes, so test with string key
;; Additional test: empty message
(assert-eq (b-hmac-sha256 "key" "The quick brown fox jumps over the lazy dog")
           "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8"
           "hmac-sha256 quick brown fox")

(println "All HMAC-SHA-256 tests passed")
