;; integration_test.airl — End-to-end test combining all Forge modules
;; Run with:
;;   cargo run --release --features jit -- run \
;;     --load lib/forge/codec.airl \
;;     --load lib/forge/schema.airl \
;;     --load lib/forge/tools.airl \
;;     --load lib/forge/provider.airl \
;;     --load lib/forge/validate.airl \
;;     --load lib/forge/chain.airl \
;;     tests/forge/integration_test.airl

;; ─── Section 1: Tool discovery via fn-metadata ───────────────────────────────

(defn add
  :sig [(a : i64) (b : i64) -> i64]
  :intent "Add two integers"
  :requires [(valid a) (valid b)]
  :ensures [(valid result)]
  :body (+ a b))

(defn multiply
  :sig [(a : i64) (b : i64) -> i64]
  :intent "Multiply two integers"
  :requires [(valid a) (valid b)]
  :ensures [(valid result)]
  :body (* a b))

(let (meta-result : _ (fn-metadata "add"))
  (do
    (assert (is-ok? meta-result) "fn-metadata must return Ok for add")
    (let (meta : _ (unwrap-or meta-result (map-new)))
      (do
        (assert (= (map-get meta "name") "add") "fn-metadata name must be add")
        (assert (= (map-get meta "intent") "Add two integers") "fn-metadata intent must match")
        (let (pnames : _ (map-get-or meta "param-names" []))
          (assert (= (length pnames) 2) "fn-metadata must report 2 params for add"))))))

;; ─── Section 2: Tool registry + schema generation ────────────────────────────

(let (reg0 : _ (make-registry))
     (reg1-result : _ (register-fn reg0 "add" (fn [a b] (add a b))))
  (do
    (assert (is-ok? reg1-result) "register-fn must succeed for add")
    (let (reg1 : _ (unwrap-or reg1-result (map-new)))
         (reg2-result : _ (register-fn reg1 "multiply" (fn [a b] (multiply a b))))
      (do
        (assert (is-ok? reg2-result) "register-fn must succeed for multiply")
        (let (reg2 : _ (unwrap-or reg2-result (map-new)))
          (do
                ;; Verify both tools registered
                (let (names : _ (list-tools reg2))
                  (do
                    (assert (= (length names) 2) "registry must have 2 tools")
                    (assert (list-contains? names "add") "registry must contain add")
                    (assert (list-contains? names "multiply") "registry must contain multiply")))

                ;; Verify schemas generated
                (let (schemas : _ (tool-schemas reg2))
                  (do
                    (assert (= (length schemas) 2) "tool-schemas must return 2 schemas")
                    (let (first-schema : _ (at schemas 0))
                      (assert (map-has first-schema "name") "schema must have name field"))))

                ;; call-tool both functions
                (let (add-result : _ (call-tool reg2 "add" [3 7]))
                  (do
                    (assert (is-ok? add-result) "call-tool add must succeed")
                    (let (add-val : _ (unwrap-or add-result 0))
                      (assert (= add-val 10) "add 3 7 must equal 10"))))

                (let (mul-result : _ (call-tool reg2 "multiply" [4 5]))
                  (do
                    (assert (is-ok? mul-result) "call-tool multiply must succeed")
                    (let (mul-val : _ (unwrap-or mul-result 0))
                      (assert (= mul-val 20) "multiply 4 5 must equal 20"))))))))))

;; ─── Section 3: Pipeline chain — json-parse → validate-keys → compute ────────

(let (step-parse : _ (make-step "json-parse" (fn [s] (json-parse s))))
     (step-validate : _ (make-step "validate-keys" (fn [m] (validate-keys m ["x" "y"]))))
     (step-compute : _ (make-step "compute" (fn [m] (+ (map-get m "x") (map-get m "y")))))
     (steps : _ [step-parse step-validate step-compute])
     (chain-result : _ (chain steps "{\"x\":10,\"y\":20}"))
  (do
    (assert (is-ok? chain-result) "3-step pipeline must succeed")
    (let (val : _ (unwrap-or chain-result 0))
      (assert (= val 30) "json x+y pipeline must produce 30"))))

;; ─── Section 4: Pipeline with validation failure (missing key) ───────────────

(let (step-parse2 : _ (make-step "json-parse2" (fn [s] (json-parse s))))
     (step-validate2 : _ (make-step "validate-keys2" (fn [m] (validate-keys m ["x" "z"]))))
     (step-compute2 : _ (make-step "compute2" (fn [m] (+ (map-get m "x") (map-get m "z")))))
     (steps2 : _ [step-parse2 step-validate2 step-compute2])
     (fail-result : _ (chain steps2 "{\"x\":10,\"y\":20}"))
  (do
    (assert (is-err? fail-result) "pipeline must Err when required key z is missing")
    (let (err-str : _ (match fail-result (Ok _) "" (Err e) e))
      (assert (contains err-str "Missing") "error message must contain 'Missing'"))))

;; ─── Section 5: Codec round-trip ─────────────────────────────────────────────

(let (original : _ (map-from ["name" "forge" "version" "1.0"]))
     (enc-result : _ (encode-map original))
  (do
    (assert (is-ok? enc-result) "encode-map must return Ok")
    (let (json-str : _ (unwrap-or enc-result "{}"))
         (dec-result : _ (decode-value json-str))
      (do
        (assert (is-ok? dec-result) "decode-value must return Ok for encoded map")
        (let (decoded : _ (match dec-result (Ok v) v (Err _) (map-new)))
          (do
            (assert (map-has decoded "name") "decoded map must have name field")
            (assert (= (map-get decoded "name") "forge") "decoded name must equal forge")
            (assert (map-has decoded "version") "decoded map must have version field")
            (assert (= (map-get decoded "version") "1.0") "decoded version must equal 1.0")))))))

;; ─── Section 6: Fan-out — apply 3 functions to same input ────────────────────

(let (double-fn : _ (fn [x] (* x 2)))
     (triple-fn : _ (fn [x] (* x 3)))
     (square-fn : _ (fn [x] (* x x)))
     (fo-result : _ (fan-out [double-fn triple-fn square-fn] 5))
  (do
    (assert (is-ok? fo-result) "fan-out must succeed for all 3 functions")
    (let (vals : _ (unwrap-or fo-result []))
      (do
        (assert (= (length vals) 3) "fan-out must return 3 results")
        (assert (= (at vals 0) 10) "double 5 must equal 10")
        (assert (= (at vals 1) 15) "triple 5 must equal 15")
        (assert (= (at vals 2) 25) "square 5 must equal 25")))))

(print "ALL INTEGRATION TESTS PASSED")
