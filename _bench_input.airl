(defn fib-helper :verify checked
  :sig [(n : i64) (a : i64) (b : i64) -> i64]
  :requires [(>= n 0)]
  :ensures [(valid result)]
  :body (if (= n 0) a
           (fib-helper (- n 1) b (+ a b))))

(defn fib-fast :verify checked
  :sig [(n : i64) -> i64]
  :requires [(>= n 0)]
  :ensures [(>= result 0)]
  :body (fib-helper n 0 1))

(println (fib-fast 0))
(println (fib-fast 10))
(println (fib-fast 20))
(println (fib-fast 25))
