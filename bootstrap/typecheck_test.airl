                         ;; ── Introspection ──
                         "type-of" (TyFunc [tv] strT)
                         "valid" (TyFunc [tv] boolT)
                         "shape" (TyFunc [tv] listA)

                         ;; ── Stdlib HOF ──
                         "map" (TyFunc [fnT listA] (TyList tvb))
                         "filter" (TyFunc [fnT listA] listA)
                         "fold" (TyFunc [fnT tv listA] tv)
                         "reverse" (TyFunc [listA] listA)
                         "concat" (TyFunc [listA listA] listA)
                         "range" (TyFunc [intT intT] (TyList intT))
                         "sort" (TyFunc [listA] listA)

                         ;; ── Result ──
                         "is-ok?" (TyFunc [tv] boolT)
                         "is-err?" (TyFunc [tv] boolT)
                         "unwrap-or" (TyFunc [tv tv] tv)
                         "map-ok" (TyFunc [tv tv] tv)
                         "map-err" (TyFunc [tv tv] tv)
                         "and-then" (TyFunc [tv tv] tv)
                         "or-else" (TyFunc [tv tv] tv)
                         "ok-or" (TyFunc [tv tv] tv)

                         ;; ── Collections ──
                         "any" (TyFunc [fnT listA] boolT)
                         "all" (TyFunc [fnT listA] boolT)
                         "merge" (TyFunc [fnT listA listA] listA)

                         ;; ── Math ──
                         "abs" (TyFunc [intT] intT)
                         "min" (TyFunc [intT intT] intT)
                         "max" (TyFunc [intT intT] intT)
                         "clamp" (TyFunc [intT intT intT] intT)
                         "sign" (TyFunc [intT] intT)
