                         "hmac-sha512" (TyFunc [strT strT] strT)
                         "sha256-bytes" (TyFunc [listA] listA)
                         "sha512-bytes" (TyFunc [listA] listA)
                         "hmac-sha256-bytes" (TyFunc [listA listA] listA)
                         "hmac-sha512-bytes" (TyFunc [listA listA] listA)
                         "pbkdf2-sha256" (TyFunc [strT strT intT intT] listA)
                         "pbkdf2-sha512" (TyFunc [strT strT intT intT] listA)
                         "base64-encode" (TyFunc [strT] strT)
                         "base64-decode" (TyFunc [strT] strT)
                         "base64-encode-bytes" (TyFunc [listA] strT)
                         "base64-decode-bytes" (TyFunc [strT] listA)
                         "random-bytes" (TyFunc [intT] listA)

                         ;; ── Compression ──
                         "gzip-compress" (TyFunc [listA] listA)
                         "gzip-decompress" (TyFunc [listA] listA)
                         "snappy-compress" (TyFunc [listA] listA)
                         "snappy-decompress" (TyFunc [listA] listA)
                         "lz4-compress" (TyFunc [listA] listA)
                         "lz4-decompress" (TyFunc [listA] listA)
                         "zstd-compress" (TyFunc [listA] listA)
                         "zstd-decompress" (TyFunc [listA] listA)

                         ;; ── Path ──
                         "path-parent" (TyFunc [strT] strT)
                         "path-filename" (TyFunc [strT] strT)
                         "path-extension" (TyFunc [strT] strT)
                         "is-absolute?" (TyFunc [strT] boolT)

                         ;; ── Regex ──
                         "regex-match" (TyFunc [strT strT] boolT)
                         "regex-find-all" (TyFunc [strT strT] listA)
                         "regex-split" (TyFunc [strT strT] listA)
                         ])))

;; ─── Core Expression Type Checking ──────────────────

(defn check-expr
  :sig [(node : List) (env : List) (reg : List) -> List]
  :intent "Type-check an AST expression node, return (Ok type) or (Err msg)"
  :requires [(valid node)]
  :ensures [(valid result)]
  :body (match node
    ;; Literals
    (ASTInt _ _ _) (Ok (TyI64))
    (ASTFloat _ _ _) (Ok (TyF64))
    (ASTStr _ _ _) (Ok (TyStr))
    (ASTBool _ _ _) (Ok (TyBool))
    (ASTNil _ _) (Ok (TyUnit))
    (ASTKeyword _ _ _) (Ok (TyStr))

    ;; Symbol lookup
    (ASTSymbol name _ _)
      (type-env-lookup env name)

    ;; If expression: cond must be Bool, branches must agree
    (ASTIf cond then-expr else-expr _ _)
      (match (check-expr cond env reg)
        (Err e) (Err e)
        (Ok cond-ty)
          (if (types-compatible cond-ty (TyBool))
            (match (check-expr then-expr env reg)
              (Err e) (Err e)
              (Ok then-ty)
                (match (check-expr else-expr env reg)
                  (Err e) (Err e)
                  (Ok else-ty)
                    (if (types-compatible then-ty else-ty)
                      (Ok then-ty)
                      (Err "if branches have incompatible types"))))
            (Err "if condition must be Bool")))

    ;; Let expression: push scope, bind each, check body, pop
    (ASTLet bindings body _ _)
      (match (check-let-bindings bindings (type-env-push env) reg)
        (Err e) (Err e)
        (Ok bound-env)
          (check-expr body bound-env reg))

    ;; Do block: check all, return type of last
    (ASTDo exprs _ _)
      (check-do-exprs exprs env reg)

    ;; Function call
    (ASTCall callee args _ _)
      (match (check-expr callee env reg)
        (Err e) (Err e)
        (Ok callee-ty)
          (match callee-ty
            (TyFunc param-tys ret-ty)
              (match (check-args args env reg)
                (Err e) (Err e)
                (Ok arg-tys)
                  ;; For variadic builtins like print, skip arity check when params is empty
                  (if (empty? param-tys)
                    (Ok ret-ty)
                    (if (= (length arg-tys) (length param-tys))
                      (if (check-arg-types arg-tys param-tys)
                        (Ok ret-ty)
                        (Err "argument type mismatch in function call"))
                      (Ok ret-ty))))
            ;; TyVar means polymorphic/unknown — allow the call
            (TyVar _) (match (check-args args env reg)
              (Err e) (Err e)
              (Ok _) (Ok (TyVar "result")))
            _ (Err "calling a non-function")))

    ;; List literal
    (ASTList items _ _)
      (if (empty? items) (Ok (TyList (TyVar "_")))
        (match (check-args items env reg)
          (Err e) (Err e)
          (Ok item-tys)
            (Ok (TyList (head item-tys)))))

    ;; Variant constructor
    (ASTVariant name args _ _)
      (match (check-args args env reg)
        (Err e) (Err e)
        (Ok arg-tys) (Ok (TyVar name)))

    ;; Lambda
    (ASTLambda params body _ _)
      (let (lenv : List (type-env-push env))
           (lenv : List (bind-lambda-params lenv params))
          (match (check-expr body lenv reg)
            (Err e) (Err e)
            (Ok body-ty)
              (Ok (TyFunc (map (fn [_p] (TyVar "_")) params) body-ty))))

    ;; Match expression
    (ASTMatch scrutinee arms _ _)
      (match (check-expr scrutinee env reg)
        (Err e) (Err e)
        (Ok scr-ty) (check-match-arms arms scr-ty env reg))

    ;; Try
    (ASTTry expr _ _)
      (match (check-expr expr env reg)
        (Err e) (Err e)
        (Ok _) (Ok (TyVar "unwrapped")))

    _ (Err "check-expr: unknown node type")))

;; ─── Helper Functions ────────────────────────────────

(defn check-let-bindings
  :sig [(bindings : List) (env : List) (reg : List) -> List]
  :intent "Type-check let bindings sequentially, threading the type env"
  :requires [(valid bindings)]
  :ensures [(valid result)]
  :body
    (if (empty? bindings) (Ok env)
      (match (head bindings)
        (ASTBinding name type-name val-expr)
          (match (check-expr val-expr env reg)
            (Err e) (Err e)
            (Ok val-ty)
              (match (resolve-type-name type-name reg)
                (Err e) (Err e)
                (Ok declared-ty)
                  (if (types-compatible val-ty declared-ty)
                    (check-let-bindings (tail bindings) (type-env-bind env name declared-ty) reg)
                    (Err (join ["let binding '" name "': value type incompatible with declared type " type-name] "")))))
        _ (Err "invalid let binding"))))

(defn check-do-exprs
  :sig [(exprs : List) (env : List) (reg : List) -> List]
  :intent "Type-check a sequence of do-block expressions, return type of last"
  :requires [(valid exprs)]
  :ensures [(valid result)]
  :body
    (if (empty? exprs) (Ok (TyUnit))
      (match (check-expr (head exprs) env reg)
        (Err e) (Err e)
        (Ok ty)
          (if (empty? (tail exprs))
            (Ok ty)
            (check-do-exprs (tail exprs) env reg)))))

(defn check-args
  :sig [(args : List) (env : List) (reg : List) -> List]
  :intent "Type-check argument list, return (Ok type-list) or (Err msg)"
  :requires [(valid args)]
  :ensures [(valid result)]
  :body (check-args-acc args env reg []))

(defn check-args-acc
  :sig [(args : List) (env : List) (reg : List) (acc : List) -> List]
  :intent "Accumulate checked argument types"
  :requires [(valid args)]
  :ensures [(valid result)]
  :body
    (if (empty? args) (Ok (reverse acc))
      (match (check-expr (head args) env reg)
        (Err e) (Err e)
        (Ok ty) (check-args-acc (tail args) env reg (cons ty acc)))))

(defn check-arg-types
  :sig [(actual : List) (expected : List) -> Bool]
  :intent "Check if actual argument types are compatible with expected parameter types"
  :requires [(valid actual)]
  :ensures [(valid result)]
  :body
    (if (empty? actual) true
      (if (empty? expected) true
        (if (types-compatible (head actual) (head expected))
          (check-arg-types (tail actual) (tail expected))
          false))))

(defn bind-lambda-params
  :sig [(env : List) (params : List) -> List]
  :intent "Bind lambda parameter names with TyVar types"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body
    (if (empty? params) env
      (bind-lambda-params (type-env-bind env (head params) (TyVar (head params))) (tail params))))

(defn check-match-arms
  :sig [(arms : List) (scr-ty : List) (env : List) (reg : List) -> List]
  :intent "Type-check match arms, verify all have compatible result types"
  :requires [(valid arms)]
  :ensures [(valid result)]
  :body
    (if (empty? arms) (Err "non-exhaustive match")
      (match (head arms)
        (ASTArm pattern body)
          (let (arm-env : List (type-env-push env))
               (arm-env : List (bind-pattern-vars arm-env pattern scr-ty))
              (match (check-expr body arm-env reg)
                (Err e) (Err e)
                (Ok arm-ty)
                  (if (empty? (tail arms))
                    (Ok arm-ty)
                    (match (check-match-arms (tail arms) scr-ty env reg)
                      (Err e) (Err e)
                      (Ok rest-ty)
                        (if (types-compatible arm-ty rest-ty)
                          (Ok arm-ty)
                          (Ok (TyVar "match-result")))))))
        _ (Err "invalid match arm"))))

(defn bind-pattern-vars
  :sig [(env : List) (pattern : List) (scr-ty : List) -> List]
  :intent "Bind variables from a pattern into the type environment"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body (match pattern
    (PatWild _ _) env
    (PatBind name _ _) (type-env-bind env name scr-ty)
    (PatLit _ _ _) env
    (PatVariant tag sub-pats _ _)
      (bind-variant-pattern-vars env sub-pats)
    _ env))

(defn bind-variant-pattern-vars
  :sig [(env : List) (sub-pats : List) -> List]
  :intent "Bind sub-pattern variables from a variant pattern"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body
    (if (empty? sub-pats) env
      (let (env : List (bind-pattern-vars env (head sub-pats) (TyVar "_")))
        (bind-variant-pattern-vars env (tail sub-pats)))))

;; ─── Top-Level and Program Checking ─────────────────

(defn check-fn
  :sig [(node : List) (env : List) (reg : List) -> List]
  :intent "Type-check a function definition, return (Ok [fn-type env]) or (Err msg)"
  :requires [(valid node)]
  :ensures [(valid result)]
  :body (match node
    (ASTDefn name sig intent requires ensures body _ _)
      (match sig
        (ASTSig params ret-name)
          (let (fn-env : List (type-env-push env))
            (match (bind-fn-params fn-env params reg [])
              (Err e) (Err e)
              (Ok param-result)
                (let (fn-env : List (at param-result 0))
                     (param-tys : List (at param-result 1))
                    (match (resolve-type-name ret-name reg)
                      (Err e) (Err e)
                      (Ok ret-ty)
                        ;; Bind function name for recursion
                        (let (fn-ty : List (TyFunc param-tys ret-ty))
                             (fn-env : List (type-env-bind fn-env name fn-ty))
                            ;; Also bind "result" for ensures
                            (let (fn-env : List (type-env-bind fn-env "result" ret-ty))
                              (match (check-expr body fn-env reg)
                                (Err e) (Err (join ["in function '" name "': " e] ""))
                                (Ok body-ty)
                                  (if (types-compatible body-ty ret-ty)
                                    (Ok [fn-ty (type-env-bind env name fn-ty)])
                                    (Err (join ["function '" name "': body type incompatible with declared return type"] ""))))))))))
        _ (Err "defn requires a sig"))
    _ (Err "check-fn: not a defn")))

(defn bind-fn-params
  :sig [(env : List) (params : List) (reg : List) (acc : List) -> List]
  :intent "Bind function parameters into env and collect their types"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body
    (if (empty? params) (Ok [env (reverse acc)])
      (match (head params)
        (ASTParam name type-name)
          (match (resolve-type-name type-name reg)
            (Err e) (Err e)
            (Ok ty)
              (bind-fn-params (type-env-bind env name ty) (tail params) reg (cons ty acc)))
        _ (Err "invalid parameter"))))

(defn check-top-level
  :sig [(node : List) (env : List) (reg : List) -> List]
  :intent "Type-check a top-level node, return (Ok [type env reg]) or (Err msg)"
  :requires [(valid node)]
  :ensures [(valid result)]
  :body (match node
    (ASTDefn name _ _ _ _ _ _ _)
      (match (check-fn node env reg)
        (Err e) (Err e)
        (Ok result)
          (Ok [(at result 0) (at result 1) reg]))
    (ASTDefType name params body _ _)
      (let (reg : List (register-deftype name params body reg))
        (Ok [(TyUnit) env reg]))
    _ (match (check-expr node env reg)
        (Err e) (Err e)
        (Ok ty) (Ok [ty env reg]))))

(defn register-deftype
  :sig [(name : String) (params : List) (body : List) (reg : List) -> List]
  :intent "Register a deftype declaration in the type registry"
  :requires [(valid name)]
  :ensures [(valid result)]
  :body
    (let (reg : List (registry-add-type reg name body))
      (match body
        (ASTSumBody variants)
          (register-sum-ctors variants name reg)
        (ASTProductBody fields)
          ;; Product type: register the type name as a constructor
          (registry-add-ctor reg name (CtorInfo name (map (fn [f] (TyVar "_")) fields)))
        _ reg)))

(defn register-sum-ctors
  :sig [(variants : List) (parent : String) (reg : List) -> List]
  :intent "Register all constructors from a sum type"
  :requires [(valid variants)]
  :ensures [(valid result)]
  :body
    (if (empty? variants) reg
      (match (head variants)
        (ASTVariantDef vname field-types)
          (let (ftys : List (map (fn [_f] (TyVar "_")) field-types))
            (register-sum-ctors (tail variants) parent
              (registry-add-ctor reg vname (CtorInfo parent ftys))))
        _ (register-sum-ctors (tail variants) parent reg))))

(defn make-prelude-registry
  :sig [(_u : i64) -> List]
  :intent "Create a registry with standard prelude types (Result, Option)"
  :requires [(valid _u)]
  :ensures [(valid result)]
  :body
    (let (reg : List (registry-new 0))
         (reg : List (registry-add-type reg "Result" true))
         (reg : List (registry-add-ctor reg "Ok" (CtorInfo "Result" [(TyVar "T")])))
         (reg : List (registry-add-ctor reg "Err" (CtorInfo "Result" [(TyVar "E")])))
         (reg : List (registry-add-type reg "Option" true))
         (reg : List (registry-add-ctor reg "Some" (CtorInfo "Option" [(TyVar "T")])))
         (reg : List (registry-add-ctor reg "None" (CtorInfo "Option" [])))
                  reg))

;; ─── Two-Pass Program Checking ───────────────────────
;; Pass 1: Register all function signatures and deftypes
;; Pass 2: Check all function bodies and expressions

(defn register-fn-sig
  :sig [(node : List) (env : List) (reg : List) -> List]
  :intent "Pre-register a function's type signature without checking the body"
  :requires [(valid node)]
  :ensures [(valid result)]
  :body (match node
    (ASTDefn name sig _ _ _ _ _ _)
      (match sig
        (ASTSig params ret-name)
          (match (bind-fn-param-types params reg [])
            (Err e) (Ok [env reg])
            (Ok param-tys)
              (match (resolve-type-name ret-name reg)
                (Err e) (Ok [env reg])
                (Ok ret-ty)
                  (let (fn-ty : List (TyFunc param-tys ret-ty))
                    (Ok [(type-env-bind env name fn-ty) reg]))))
        _ (Ok [env reg]))
    (ASTDefType name params body _ _)
      (Ok [env (register-deftype name params body reg)])
    _ (Ok [env reg])))

(defn bind-fn-param-types
  :sig [(params : List) (reg : List) (acc : List) -> List]
  :intent "Resolve parameter types without binding into env"
  :requires [(valid params)]
  :ensures [(valid result)]
  :body
    (if (empty? params) (Ok (reverse acc))
      (match (head params)
        (ASTParam name type-name)
          (match (resolve-type-name type-name reg)
            (Err e) (Err e)
            (Ok ty) (bind-fn-param-types (tail params) reg (cons ty acc)))
        _ (Err "invalid parameter"))))

(defn register-all-top-levels
  :sig [(nodes : List) (env : List) (reg : List) -> List]
  :intent "Pass 1: register all function sigs and deftypes"
  :requires [(valid nodes)]
  :ensures [(valid result)]
  :body
    (if (empty? nodes) (Ok [env reg])
      (match (register-fn-sig (head nodes) env reg)
        (Err e) (Err e)
        (Ok result)
          (register-all-top-levels (tail nodes) (at result 0) (at result 1)))))

(defn check-all-top-levels
  :sig [(nodes : List) (env : List) (reg : List) -> List]
  :intent "Pass 2: type-check all top-level nodes, collecting all errors"
  :requires [(valid nodes)]
  :ensures [(valid result)]
  :body (check-all-top-levels-acc nodes env reg []))

(defn check-all-top-levels-acc
  :sig [(nodes : List) (env : List) (reg : List) (errors : List) -> List]
  :intent "Accumulate type errors across all top-level nodes"
  :requires [(valid nodes)]
  :ensures [(valid result)]
  :body
    (if (empty? nodes)
      (if (empty? errors) (Ok env)
        (Err (join errors "; ")))
      (match (check-top-level (head nodes) env reg)
        (Err e)
          (check-all-top-levels-acc (tail nodes) env reg (append errors e))
        (Ok result)
          (check-all-top-levels-acc (tail nodes) (at result 1) (at result 2) errors))))

(defn type-check-program
  :sig [(nodes : List) (env : List) (reg : List) -> List]
  :intent "Two-pass type-check: register all sigs, then check all bodies"
  :requires [(valid nodes)]
  :ensures [(valid result)]
  :body
    ;; Pass 1: register all function signatures and deftypes
    (match (register-all-top-levels nodes env reg)
      (Err e) (Err e)
      (Ok pass1-result)
        ;; Pass 2: check all bodies with everything in scope
        (check-all-top-levels nodes (at pass1-result 0) (at pass1-result 1))))

;; ═══ TYPECHECK TESTS ═════════════════════════════════

(defn check-source
  :sig [(source : String) -> List]
  :intent "Parse source, type-check, return type or error"
  :requires [(valid source)]
  :ensures [(valid result)]
  :body
    (match (parse source)
      (Err e) (Err e)
      (Ok nodes)
        (if (empty? nodes)
          (Err "no expressions")
          (let (env : List (make-builtin-env 0))
               (reg : List (make-prelude-registry 0))
              (check-expr (head nodes) env reg)))))

(defn check-program-source
  :sig [(source : String) -> List]
  :intent "Parse source, type-check as program, return Ok or Err"
  :requires [(valid source)]
  :ensures [(valid result)]
  :body
    (match (parse source)
      (Err e) (Err e)
      (Ok nodes)
        (let (env : List (make-builtin-env 0))
             (reg : List (make-prelude-registry 0))
            (type-check-program nodes env reg))))

(print "=== typecheck expression tests ===")

(assert-eq (check-source "42") (Ok (TyI64)))
(assert-eq (check-source "3.14") (Ok (TyF64)))
(assert-eq (check-source "true") (Ok (TyBool)))
(assert-eq (check-source "\"hello\"") (Ok (TyStr)))
(assert-eq (check-source "nil") (Ok (TyUnit)))
(assert-eq (check-source "(+ 1 2)") (Ok (TyVar "a")))
(assert-eq (check-source "(< 1 2)") (Ok (TyBool)))
(assert-eq (check-source "(= 1 1)") (Ok (TyBool)))
(assert-eq (check-source "(not true)") (Ok (TyBool)))

(match (check-source "(if 42 1 2)")
  (Err _) (print "PASS: if cond must be bool")
  _ (print "FAIL"))

(assert-eq (check-source "(let (x : i64 42) x)") (Ok (TyI64)))

(match (check-source "(let (x : i64 \"hi\") x)")
  (Err _) (print "PASS: let type mismatch")
  _ (print "FAIL"))

(assert-eq (check-source "(do 1 2 3)") (Ok (TyI64)))

(match (check-source "undefined_var")
  (Err _) (print "PASS: undefined symbol")
  _ (print "FAIL"))

(match (check-source "[1 2 3]")
  (Ok ty) (match ty (TyList _) (print "PASS: list literal") _ (print "FAIL"))
  (Err e) (print "FAIL:" e))

(print "=== typecheck expression tests complete ===")

(print "=== typecheck function tests ===")

(match (check-program-source "(defn add :sig [(a : i64) (b : i64) -> i64] :requires [(valid a)] :ensures [(valid result)] :body (+ a b)) (add 1 2)")
  (Ok _) (print "PASS: function def and call")
  (Err e) (print "FAIL:" e))

(assert-eq (check-source "(match 42 x x)") (Ok (TyI64)))

(match (check-source "(fn [x] (+ x 1))")
  (Ok ty) (match ty (TyFunc _ _) (print "PASS: lambda type") _ (print "FAIL"))
  (Err e) (print "FAIL:" e))

(match (check-program-source "(deftype Color (| (Red) (Green) (Blue))) (Red)")
  (Ok _) (print "PASS: deftype + variant")
  (Err e) (print "FAIL:" e))

(match (check-program-source "(defn bad :sig [(x : i64) -> Bool] :requires [(valid x)] :ensures [(valid result)] :body \"hello\"")
  (Err _) (print "PASS: wrong return type rejected")
  (Ok _) (print "FAIL"))

(print "=== typecheck function tests complete ===")

;; ─── Integration: type-check bootstrap modules ──────

(print "=== typecheck integration tests ===")

;; Lexer
(let (lexer-source : String (read-file "bootstrap/lexer.airl"))
  (match (parse lexer-source)
    (Err e) (print "FAIL: lexer parse:" e)
    (Ok nodes)
      (let (env : List (make-builtin-env 0))
           (reg : List (make-prelude-registry 0))
          (match (type-check-program nodes env reg)
            (Ok _) (print "PASS: lexer type-checks clean")
            (Err e) (print "FAIL: lexer:" e)))))

;; Parser (needs lexer sigs)
(let (lexer-source : String (read-file "bootstrap/lexer.airl"))
  (match (parse lexer-source)
    (Err e) (print "FAIL: lexer parse:" e)
    (Ok lexer-nodes)
      (let (parser-source : String (read-file "bootstrap/parser.airl"))
        (match (parse parser-source)
          (Err e) (print "FAIL: parser parse:" e)
          (Ok parser-nodes)
            (let (env : List (make-builtin-env 0))
                 (reg : List (make-prelude-registry 0))
                (match (register-all-top-levels lexer-nodes env reg)
                  (Err e) (print "FAIL:" e)
                  (Ok lr)
                    (match (type-check-program parser-nodes (at lr 0) (at lr 1))
                      (Ok _) (print "PASS: parser type-checks clean")
                      (Err e) (print "FAIL: parser:" e))))))))

;; Eval (needs lexer+parser sigs)
(let (lexer-source : String (read-file "bootstrap/lexer.airl"))
  (match (parse lexer-source)
    (Err e) (print "FAIL: lexer parse:" e)
    (Ok lexer-nodes)
      (let (parser-source : String (read-file "bootstrap/parser.airl"))
        (match (parse parser-source)
          (Err e) (print "FAIL: parser parse:" e)
          (Ok parser-nodes)
            (let (eval-source : String (read-file "bootstrap/eval.airl"))
              (match (parse eval-source)
                (Err e) (print "FAIL: eval parse:" e)
                (Ok eval-nodes)
                  (let (env : List (make-builtin-env 0))
                       (reg : List (make-prelude-registry 0))
                      (match (register-all-top-levels lexer-nodes env reg)
                        (Err e) (print "FAIL:" e)
                        (Ok lr)
                          (match (register-all-top-levels parser-nodes (at lr 0) (at lr 1))
                            (Err e) (print "FAIL:" e)
                            (Ok pr)
                              (match (type-check-program eval-nodes (at pr 0) (at pr 1))
                                (Ok _) (print "PASS: eval type-checks clean")
                                (Err e) (print "FAIL: eval:" e)))))))))))

(print "=== typecheck integration tests complete ===")
(print "=== all typecheck tests complete ===")
