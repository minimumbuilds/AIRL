;; bootstrap/eval.airl — Bootstrap evaluator for AIRL
;; Interprets AST nodes produced by bootstrap/parser.airl

;; ─── Value Unwrap Helpers ─────────────────────────────────

(defn unwrap-int
  :sig [(v : List) -> i64]
  :intent "Extract integer from ValInt"
  :requires [(valid v)]
  :ensures [(valid result)]
  :body (match v
    (ValInt n) n
    _ (do (print "ERROR: expected ValInt, got" v) 0)))

(defn unwrap-float
  :sig [(v : List) -> f64]
  :intent "Extract float from ValFloat"
  :requires [(valid v)]
  :ensures [(valid result)]
  :body (match v
    (ValFloat n) n
    _ (do (print "ERROR: expected ValFloat, got" v) 0.0)))

(defn unwrap-str
  :sig [(v : List) -> Str]
  :intent "Extract string from ValStr"
  :requires [(valid v)]
  :ensures [(valid result)]
  :body (match v
    (ValStr s) s
    _ (do (print "ERROR: expected ValStr, got" v) "")))

(defn unwrap-bool
  :sig [(v : List) -> Bool]
  :intent "Extract bool from ValBool"
  :requires [(valid v)]
  :ensures [(valid result)]
  :body (match v
    (ValBool b) b
    _ (do (print "ERROR: expected ValBool, got" v) false)))

(defn unwrap-list
  :sig [(v : List) -> List]
  :intent "Extract list from ValList"
  :requires [(valid v)]
  :ensures [(valid result)]
  :body (match v
    (ValList xs) xs
    _ (do (print "ERROR: expected ValList, got" v) [])))

(defn unwrap-raw
  :sig [(v : List) -> List]
  :intent "Extract the raw AIRL value from any Val wrapper"
  :requires [(valid v)]
  :ensures [(valid result)]
  :body (match v
    (ValInt n) n
    (ValFloat n) n
    (ValStr s) s
    (ValBool b) b
    (ValNil) nil
    _ v))

;; ─── Environment Operations ──────────────────────────────
;; Environment is a list of maps (frame stack). Head = innermost scope.

(defn env-new
  :sig [(_u : i64) -> List]
  :intent "Create a new environment with one empty frame"
  :requires [(valid _u)]
  :ensures [(valid result)]
  :body [(map-new)])

(defn env-push
  :sig [(env : List) -> List]
  :intent "Push a new empty frame onto the environment"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body (cons (map-new) env))

(defn env-pop
  :sig [(env : List) -> List]
  :intent "Pop the innermost frame from the environment"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body (tail env))

(defn env-bind
  :sig [(env : List) (name : Str) (val : List) -> List]
  :intent "Bind a name to a value in the top frame"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body (cons (map-set (head env) name val) (tail env)))

(defn env-get
  :sig [(env : List) (name : Str) -> List]
  :intent "Look up a name in the environment, searching from innermost frame outward"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body (if (empty? env)
    (Err (join ["undefined symbol: " name] ""))
    (if (map-has (head env) name)
      (Ok (map-get (head env) name))
      (env-get (tail env) name))))

;; ─── Builtin Dispatch ────────────────────────────────────

(defn print-val-args
  :sig [(args : List) -> List]
  :intent "Print all Val-wrapped arguments via the real print builtin"
  :requires [(valid args)]
  :ensures [(valid result)]
  :body (if (empty? args) nil
    (if (= (length args) 1)
      (print (unwrap-raw (head args)))
      (if (= (length args) 2)
        (print (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))
        (if (= (length args) 3)
          (print (unwrap-raw (at args 0)) (unwrap-raw (at args 1)) (unwrap-raw (at args 2)))
          (print (unwrap-raw (at args 0)) (unwrap-raw (at args 1)) (unwrap-raw (at args 2)) (unwrap-raw (at args 3))))))))

(defn call-builtin
  :sig [(name : Str) (args : List) -> List]
  :intent "Dispatch a builtin call by name, returning (Ok val) or (Err msg)"
  :requires [(valid name)]
  :ensures [(valid result)]
  :body
    ;; Arithmetic — + dispatches on type (int vs string concat)
    (if (= name "+") (match (at args 0)
      (ValStr s) (Ok (ValStr (+ s (unwrap-str (at args 1)))))
      _ (Ok (ValInt (+ (unwrap-int (at args 0)) (unwrap-int (at args 1))))))
    (if (= name "-") (Ok (ValInt (- (unwrap-int (at args 0)) (unwrap-int (at args 1)))))
    (if (= name "*") (Ok (ValInt (* (unwrap-int (at args 0)) (unwrap-int (at args 1)))))
    (if (= name "/") (Ok (ValInt (/ (unwrap-int (at args 0)) (unwrap-int (at args 1)))))
    (if (= name "%") (Ok (ValInt (% (unwrap-int (at args 0)) (unwrap-int (at args 1)))))

    ;; Comparison
    (if (= name "=")  (Ok (ValBool (= (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))))
    (if (= name "!=") (Ok (ValBool (!= (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))))
    (if (= name "<")  (Ok (ValBool (< (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))))
    (if (= name ">")  (Ok (ValBool (> (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))))
    (if (= name "<=") (Ok (ValBool (<= (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))))
    (if (= name ">=") (Ok (ValBool (>= (unwrap-raw (at args 0)) (unwrap-raw (at args 1)))))

    ;; Logic
    (if (= name "not") (Ok (ValBool (not (unwrap-bool (at args 0)))))
    (if (= name "and") (Ok (ValBool (if (unwrap-bool (at args 0)) (unwrap-bool (at args 1)) false)))
    (if (= name "or")  (Ok (ValBool (if (unwrap-bool (at args 0)) true (unwrap-bool (at args 1)))))
    (if (= name "xor") (Ok (ValBool (xor (unwrap-bool (at args 0)) (unwrap-bool (at args 1)))))

    ;; List operations
    (if (= name "head")   (Ok (head (unwrap-list (at args 0))))
    (if (= name "tail")   (Ok (ValList (tail (unwrap-list (at args 0)))))
    (if (= name "cons")   (Ok (ValList (cons (at args 0) (unwrap-list (at args 1)))))
    (if (= name "empty?") (Ok (ValBool (empty? (unwrap-list (at args 0)))))
    (if (= name "at")     (Ok (at (unwrap-list (at args 0)) (unwrap-int (at args 1))))
    (if (= name "append") (Ok (ValList (append (unwrap-list (at args 0)) (at args 1))))

    ;; length — works on both lists and strings
    (if (= name "length") (match (at args 0)
      (ValStr s) (Ok (ValInt (length s)))
      (ValList xs) (Ok (ValInt (length xs)))
      _ (Ok (ValInt (length (unwrap-list (at args 0))))))

    ;; String operations — character access
    (if (= name "char-at")    (Ok (ValStr (char-at (unwrap-str (at args 0)) (unwrap-int (at args 1)))))
    (if (= name "substring")  (Ok (ValStr (substring (unwrap-str (at args 0)) (unwrap-int (at args 1)) (unwrap-int (at args 2)))))
    (if (= name "chars")      (Ok (ValList (map (fn [c] (ValStr c)) (chars (unwrap-str (at args 0))))))

    ;; String operations — search
    (if (= name "contains")    (Ok (ValBool (contains (unwrap-str (at args 0)) (unwrap-str (at args 1)))))
    (if (= name "starts-with") (Ok (ValBool (starts-with (unwrap-str (at args 0)) (unwrap-str (at args 1)))))
    (if (= name "ends-with")   (Ok (ValBool (ends-with (unwrap-str (at args 0)) (unwrap-str (at args 1)))))
    (if (= name "index-of")    (Ok (ValInt (index-of (unwrap-str (at args 0)) (unwrap-str (at args 1)))))

    ;; String operations — transformation
    (if (= name "trim")     (Ok (ValStr (trim (unwrap-str (at args 0)))))
    (if (= name "to-upper") (Ok (ValStr (to-upper (unwrap-str (at args 0)))))
    (if (= name "to-lower") (Ok (ValStr (to-lower (unwrap-str (at args 0)))))
    (if (= name "replace")  (Ok (ValStr (replace (unwrap-str (at args 0)) (unwrap-str (at args 1)) (unwrap-str (at args 2)))))

    ;; String operations — split/join
    (if (= name "split") (Ok (ValList (map (fn [s] (ValStr s)) (split (unwrap-str (at args 0)) (unwrap-str (at args 1))))))
    (if (= name "join")  (Ok (ValStr (join (map (fn [v] (unwrap-str v)) (unwrap-list (at args 0))) (unwrap-str (at args 1)))))

    ;; Map operations
    (if (= name "map-new")     (Ok (ValMap (map-new)))
    (if (= name "map-from")    (Ok (ValMap (map-from (unwrap-raw (at args 0)))))
    (if (= name "map-get")     (let (v : List(map-get (unwrap-raw (at args 0)) (unwrap-str (at args 1))))
                                  (if (= v nil) (Ok (ValNil)) (Ok v)))
    (if (= name "map-get-or")  (Ok (map-get-or (unwrap-raw (at args 0)) (unwrap-str (at args 1)) (at args 2)))
    (if (= name "map-set")     (Ok (ValMap (map-set (unwrap-raw (at args 0)) (unwrap-str (at args 1)) (at args 2))))
    (if (= name "map-has")     (Ok (ValBool (map-has (unwrap-raw (at args 0)) (unwrap-str (at args 1)))))
    (if (= name "map-remove")  (Ok (ValMap (map-remove (unwrap-raw (at args 0)) (unwrap-str (at args 1)))))
    (if (= name "map-keys")    (Ok (ValList (map (fn [k] (ValStr k)) (map-keys (unwrap-raw (at args 0))))))
    (if (= name "map-values")  (Ok (ValList (map-values (unwrap-raw (at args 0)))))
    (if (= name "map-size")    (Ok (ValInt (map-size (unwrap-raw (at args 0)))))

    ;; File I/O
    (if (= name "read-file")    (match (read-file (unwrap-str (at args 0)))
      err (Err (+ "read-file error: " err))
      content (Ok (ValStr content)))
    (if (= name "write-file")   (do (write-file (unwrap-str (at args 0)) (unwrap-str (at args 1))) (Ok (ValBool true)))
    (if (= name "file-exists?") (Ok (ValBool (file-exists? (unwrap-str (at args 0)))))

    ;; I/O — print is variadic, print all args
    (if (= name "print") (do (print-val-args args) (Ok (ValNil)))

    ;; Utility
    (if (= name "valid") (Ok (ValBool true))
    (if (= name "type-of")
      (match (at args 0)
        (ValInt _) (Ok (ValStr "Int"))
        (ValFloat _) (Ok (ValStr "Float"))
        (ValStr _) (Ok (ValStr "Str"))
        (ValBool _) (Ok (ValStr "Bool"))
        (ValNil) (Ok (ValStr "Nil"))
        (ValList _) (Ok (ValStr "List"))
        (ValMap _) (Ok (ValStr "Map"))
        (ValVariant _ _) (Ok (ValStr "Variant"))
        (ValFn _ _ _ _) (Ok (ValStr "Fn"))
        (ValLambda _ _ _) (Ok (ValStr "Lambda"))
        (ValBuiltin _) (Ok (ValStr "Builtin"))
        _ (Ok (ValStr "Unknown")))

    ;; Unknown builtin
    (Err (+ "unknown builtin: " name))
    ))))))))))))))))))))))))))))))))))))))))))))))))))))

(defn make-initial-env
  :sig [(_u : i64) -> List]
  :intent "Create environment with all builtins bound"
  :requires [(valid _u)]
  :ensures [(valid result)]
  :body
    (let (e : List(env-new 0))
         (e : List(env-bind e "+" (ValBuiltin "+")))
         (e : List(env-bind e "-" (ValBuiltin "-")))
         (e : List(env-bind e "*" (ValBuiltin "*")))
         (e : List(env-bind e "/" (ValBuiltin "/")))
         (e : List(env-bind e "%" (ValBuiltin "%")))
         (e : List(env-bind e "=" (ValBuiltin "=")))
         (e : List(env-bind e "!=" (ValBuiltin "!=")))
         (e : List(env-bind e "<" (ValBuiltin "<")))
         (e : List(env-bind e ">" (ValBuiltin ">")))
         (e : List(env-bind e "<=" (ValBuiltin "<=")))
         (e : List(env-bind e ">=" (ValBuiltin ">=")))
         (e : List(env-bind e "not" (ValBuiltin "not")))
         (e : List(env-bind e "and" (ValBuiltin "and")))
         (e : List(env-bind e "or" (ValBuiltin "or")))
         (e : List(env-bind e "head" (ValBuiltin "head")))
         (e : List(env-bind e "tail" (ValBuiltin "tail")))
         (e : List(env-bind e "cons" (ValBuiltin "cons")))
         (e : List(env-bind e "empty?" (ValBuiltin "empty?")))
         (e : List(env-bind e "length" (ValBuiltin "length")))
         (e : List(env-bind e "at" (ValBuiltin "at")))
         (e : List(env-bind e "append" (ValBuiltin "append")))
         (e : List(env-bind e "char-at" (ValBuiltin "char-at")))
         (e : List(env-bind e "substring" (ValBuiltin "substring")))
         (e : List(env-bind e "chars" (ValBuiltin "chars")))
         (e : List(env-bind e "contains" (ValBuiltin "contains")))
         (e : List(env-bind e "starts-with" (ValBuiltin "starts-with")))
         (e : List(env-bind e "ends-with" (ValBuiltin "ends-with")))
         (e : List(env-bind e "index-of" (ValBuiltin "index-of")))
         (e : List(env-bind e "trim" (ValBuiltin "trim")))
         (e : List(env-bind e "to-upper" (ValBuiltin "to-upper")))
         (e : List(env-bind e "to-lower" (ValBuiltin "to-lower")))
         (e : List(env-bind e "replace" (ValBuiltin "replace")))
         (e : List(env-bind e "split" (ValBuiltin "split")))
         (e : List(env-bind e "join" (ValBuiltin "join")))
         (e : List(env-bind e "map-new" (ValBuiltin "map-new")))
         (e : List(env-bind e "map-from" (ValBuiltin "map-from")))
         (e : List(env-bind e "map-get" (ValBuiltin "map-get")))
         (e : List(env-bind e "map-get-or" (ValBuiltin "map-get-or")))
         (e : List(env-bind e "map-set" (ValBuiltin "map-set")))
         (e : List(env-bind e "map-has" (ValBuiltin "map-has")))
         (e : List(env-bind e "map-remove" (ValBuiltin "map-remove")))
         (e : List(env-bind e "map-keys" (ValBuiltin "map-keys")))
         (e : List(env-bind e "map-values" (ValBuiltin "map-values")))
         (e : List(env-bind e "map-size" (ValBuiltin "map-size")))
         (e : List(env-bind e "read-file" (ValBuiltin "read-file")))
         (e : List(env-bind e "write-file" (ValBuiltin "write-file")))
         (e : List(env-bind e "file-exists?" (ValBuiltin "file-exists?")))
         (e : List(env-bind e "print" (ValBuiltin "print")))
         (e : List(env-bind e "type-of" (ValBuiltin "type-of")))
         (e : List(env-bind e "valid" (ValBuiltin "valid")))
         (e : List(env-bind e "xor" (ValBuiltin "xor")))
      e))

(defn eval-args-acc
  :sig [(args : List) (env : List) (acc : List) -> List]
  :intent "Accumulate evaluated argument values"
  :requires [(valid args)]
  :ensures [(valid result)]
  :body
    (if (empty? args) (Ok [acc env])
      (match (eval-node (head args) env)
        (Err e) (Err e)
        (Ok pair)
          (eval-args-acc (tail args) (at pair 1) (append acc (at pair 0))))))

(defn eval-args
  :sig [(args : List) (env : List) -> List]
  :intent "Evaluate a list of argument expressions left-to-right"
  :requires [(valid args)]
  :ensures [(valid result)]
  :body (eval-args-acc args env []))

;; ─── Control Flow Helpers ────────────────────────────────

(defn eval-let-bindings
  :sig [(bindings : List) (env : List) -> List]
  :intent "Evaluate let bindings sequentially, threading env"
  :requires [(valid bindings)]
  :ensures [(valid result)]
  :body
    (if (empty? bindings) (Ok env)
      (match (head bindings)
        (ASTBinding name _ val-expr)
          (match (eval-node val-expr env)
            (Err e) (Err e)
            (Ok pair)
              (eval-let-bindings (tail bindings) (env-bind (at pair 1) name (at pair 0))))
        _ (Err "eval: invalid let binding"))))

(defn eval-do
  :sig [(exprs : List) (env : List) -> List]
  :intent "Evaluate a sequence of expressions, threading env, return last value"
  :requires [(valid exprs)]
  :ensures [(valid result)]
  :body
    (if (empty? exprs) (Ok [(ValNil) env])
      (match (eval-node (head exprs) env)
        (Err e) (Err e)
        (Ok pair)
          (if (empty? (tail exprs))
            (Ok pair)
            (eval-do (tail exprs) (at pair 1))))))

;; ─── Pattern Matching ────────────────────────────────────

(defn try-match-patterns
  :sig [(patterns : List) (values : List) -> List]
  :intent "Match a list of patterns against a list of values, collecting bindings"
  :requires [(valid patterns)]
  :ensures [(valid result)]
  :body
    (if (empty? patterns) (Ok [])
      (if (empty? values) (Err "no match")
        (match (try-match-pattern (head patterns) (head values))
          (Err e) (Err e)
          (Ok binds1)
            (match (try-match-patterns (tail patterns) (tail values))
              (Err e) (Err e)
              (Ok binds2) (Ok (concat binds1 binds2)))))))

(defn try-match-pattern
  :sig [(pattern : List) (value : List) -> List]
  :intent "Try to match a pattern against a value, returning (Ok bindings) or (Err msg)"
  :requires [(valid pattern)]
  :ensures [(valid result)]
  :body (match pattern
    (PatWild _ _) (Ok [])
    (PatBind name _ _) (Ok [[name value]])
    (PatLit lit-val _ _)
      (if (= (unwrap-raw value) lit-val) (Ok [])
        (Err "no match"))
    (PatVariant tag sub-pats _ _)
      (match value
        (ValVariant vtag inner)
          (if (= tag vtag)
            (if (empty? sub-pats)
              (Ok [])
              (if (= (length sub-pats) 1)
                (try-match-pattern (head sub-pats) inner)
                (match inner
                  (ValList items) (try-match-patterns sub-pats items)
                  _ (Err "no match"))))
            (Err "no match"))
        _ (Err "no match"))
    _ (Err "no match")))

(defn bind-match-bindings
  :sig [(env : List) (bindings : List) -> List]
  :intent "Bind pattern match capture bindings into the top frame"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body
    (if (empty? bindings) env
      (let (pair : List(head bindings))
        (bind-match-bindings
          (env-bind env (at pair 0) (at pair 1))
          (tail bindings)))))

(defn eval-match-arms
  :sig [(arms : List) (value : List) (env : List) -> List]
  :intent "Try each match arm against the scrutinee value"
  :requires [(valid arms)]
  :ensures [(valid result)]
  :body
    (if (empty? arms)
      (Err "non-exhaustive match")
      (match (head arms)
        (ASTArm pattern body)
          (match (try-match-pattern pattern value)
            (Ok bindings)
              (let (match-env : List(bind-match-bindings (env-push env) bindings))
                (match (eval-node body match-env)
                  (Err e) (Err e)
                  (Ok pair) (Ok [(at pair 0) (env-pop (at pair 1))])))
            (Err _) (eval-match-arms (tail arms) value env))
        _ (Err "eval: invalid match arm"))))

;; ─── Function Helpers ────────────────────────────────────

(defn extract-param-names
  :sig [(sig : List) -> List]
  :intent "Extract parameter name strings from an ASTSig node"
  :requires [(valid sig)]
  :ensures [(valid result)]
  :body (match sig
    (ASTSig params _)
      (map (fn [p] (match p (ASTParam name _) name _ "?")) params)
    _ []))

(defn bind-params
  :sig [(env : List) (names : List) (vals : List) -> List]
  :intent "Bind parameter names to argument values in the top frame"
  :requires [(valid env)]
  :ensures [(valid result)]
  :body
    (if (empty? names) env
      (bind-params
        (env-bind env (head names) (if (empty? vals) (ValNil) (head vals)))
        (tail names)
        (if (empty? vals) [] (tail vals)))))

;; ─── Evaluator Core ──────────────────────────────────────

(defn eval-list-items
  :sig [(items : List) (env : List) (acc : List) -> List]
  :intent "Evaluate list literal items left-to-right"
  :requires [(valid items)]
  :ensures [(valid result)]
  :body
    (if (empty? items) (Ok [acc env])
      (match (eval-node (head items) env)
        (Err e) (Err e)
        (Ok pair)
          (eval-list-items (tail items) (at pair 1) (append acc (at pair 0))))))

(defn eval-node
  :sig [(node : List) (env : List) -> List]
  :intent "Evaluate a single AST node, returning (Ok [val env]) or (Err msg)"
  :requires [(valid node)]
  :ensures [(valid result)]
  :body (match node
    (ASTInt v _ _) (Ok [(ValInt v) env])
    (ASTFloat v _ _) (Ok [(ValFloat v) env])
    (ASTStr v _ _) (Ok [(ValStr v) env])
    (ASTBool v _ _) (Ok [(ValBool v) env])
    (ASTNil _ _) (Ok [(ValNil) env])
    (ASTKeyword k _ _) (Ok [(ValStr (+ ":" k)) env])

    (ASTSymbol name _ _)
      (match (env-get env name)
        (Ok val) (Ok [val env])
        (Err msg) (Err msg))

    (ASTList items _ _)
      (match (eval-list-items items env [])
        (Err e) (Err e)
        (Ok pair) (Ok [(ValList (at pair 0)) (at pair 1)]))

    (ASTCall callee args _ _)
      (match (eval-node callee env)
        (Err e) (Err e)
        (Ok callee-pair)
          (let (callee-val : List(at callee-pair 0))
               (env2 : List(at callee-pair 1))
              (match (eval-args args env2)
                (Err e) (Err e)
                (Ok args-pair)
                  (let (arg-vals : List(at args-pair 0))
                       (env3 : List(at args-pair 1))
                      (match callee-val
                        (ValBuiltin name)
                          (match (call-builtin name arg-vals)
                            (Ok val) (Ok [val env3])
                            (Err e) (Err e))

                        (ValFn fn-name params body captured-env)
                          (let (call-env : List(env-bind (bind-params (env-push captured-env) params arg-vals) fn-name callee-val))
                            (match (eval-node body call-env)
                              (Err e) (Err e)
                              (Ok pair) (Ok [(at pair 0) env3])))

                        (ValLambda params body captured-env)
                          (let (call-env : List(bind-params (env-push captured-env) params arg-vals))
                            (match (eval-node body call-env)
                              (Err e) (Err e)
                              (Ok pair) (Ok [(at pair 0) env3])))

                        _ (Err "eval: not callable"))))))

    (ASTIf cond then-expr else-expr _ _)
      (match (eval-node cond env)
        (Err e) (Err e)
        (Ok cond-pair)
          (let (cond-val : List(at cond-pair 0))
               (env2 : List(at cond-pair 1))
              (if (unwrap-bool cond-val)
                (eval-node then-expr env2)
                (eval-node else-expr env2))))

    (ASTLet bindings body _ _)
      (let (env2 : List(env-push env))
        (match (eval-let-bindings bindings env2)
          (Err e) (Err e)
          (Ok bound-env)
            (match (eval-node body bound-env)
              (Err e) (Err e)
              (Ok pair) (Ok [(at pair 0) (env-pop (at pair 1))]))))

    (ASTDo exprs _ _)
      (eval-do exprs env)

    (ASTMatch scrutinee arms _ _)
      (match (eval-node scrutinee env)
        (Err e) (Err e)
        (Ok scr-pair)
          (eval-match-arms arms (at scr-pair 0) (at scr-pair 1)))

    (ASTVariant name args _ _)
      (if (empty? args)
        (Ok [(ValVariant name (ValNil)) env])
        (match (eval-args args env)
          (Err e) (Err e)
          (Ok args-pair)
            (let (vals : List(at args-pair 0))
                 (env2 : List(at args-pair 1))
                (if (= (length vals) 1)
                  (Ok [(ValVariant name (head vals)) env2])
                  (Ok [(ValVariant name (ValList vals)) env2])))))

    (ASTTry expr _ _)
      (match (eval-node expr env)
        (Err e) (Err e)
        (Ok pair)
          (match (at pair 0)
            (ValVariant "Ok" inner) (Ok [inner (at pair 1)])
            (ValVariant "Err" inner) (Err (+ "Err: " (unwrap-raw inner)))
            _ (Err "try on non-Result value")))

    (ASTLambda params body _ _)
      (Ok [(ValLambda params body env) env])

    _ (Err "eval-node: unknown node type")))

;; ─── Top-Level Evaluation ────────────────────────────────

(defn eval-top-level
  :sig [(node : List) (env : List) -> List]
  :intent "Evaluate a top-level node (defn or expression)"
  :requires [(valid node)]
  :ensures [(valid result)]
  :body (match node
    (ASTDefn name sig _ _ _ body _ _)
      (let (param-names : List(extract-param-names sig))
           (fn-val : List(ValFn name param-names body env))
          (Ok [(ValNil) (env-bind env name fn-val)]))
    _ (eval-node node env)))

(defn eval-program
  :sig [(nodes : List) (env : List) -> List]
  :intent "Evaluate a list of top-level nodes sequentially, threading env"
  :requires [(valid nodes)]
  :ensures [(valid result)]
  :body
    (if (empty? nodes) (Ok [(ValNil) env])
      (match (eval-top-level (head nodes) env)
        (Err e) (Err e)
        (Ok pair)
          (if (empty? (tail nodes))
            (Ok pair)
            (eval-program (tail nodes) (at pair 1))))))

;; ─── Full Pipeline ───────────────────────────────────────

(defn run-source
  :sig [(source : Str) -> List]
  :intent "Lex, parse, and evaluate an AIRL source string"
  :requires [(valid source)]
  :ensures [(valid result)]
  :body
    (match (lex source)
      (Err e) (Err e)
      (Ok tokens)
        (match (parse-sexpr-all tokens)
          (Err e) (Err e)
          (Ok sexprs)
            (match (parse-program sexprs)
              (Err e) (Err e)
              (Ok ast-nodes)
                (eval-program ast-nodes (make-initial-env 0))))))

(defn run-file
  :sig [(path : Str) -> List]
  :intent "Read an AIRL source file and evaluate it through the full pipeline"
  :requires [(valid path)]
  :ensures [(valid result)]
  :body
    (let (source : String (read-file path))
      (match (run-source source)
        (Ok pair) (Ok (at pair 0))
        (Err e) (do (print "Error:" e) (Err e)))))
