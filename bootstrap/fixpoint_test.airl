;; bootstrap/fixpoint_test.airl — Bytecode compiler fixpoint tests
;; Requires: bootstrap/lexer.airl, bootstrap/parser.airl, bootstrap/bc_compiler.airl (loaded first)
;;
;; Tests that bc-compile-program is deterministic: compiling the same source
;; twice produces bitwise-identical BCFunc output (the fixpoint property).
;;
;; Tier 1: compile fixpoint_tier1_program.airl twice — assert BC1 == BC2
;; Tier 2: compile bc_compiler.airl itself twice — assert BC1 == BC2 (self-hosting determinism)
;;
;; Run with:
;;   cat bootstrap/lexer.airl bootstrap/parser.airl bootstrap/bc_compiler.airl bootstrap/fixpoint_test.airl > /tmp/fixpoint_bc_full.airl
;;   RUST_MIN_STACK=67108864 timeout 120 target/release/airl-driver run /tmp/fixpoint_bc_full.airl

;; ── Helpers ─────────────────────────────────────────────

(defn parse-source
  :sig [(source : String) -> _]
  :intent "Lex and parse source string into AST nodes"
  :requires [(valid source)]
  :ensures [(valid result)]
  :body
    (match (lex source)
      (Err e) (Err e)
      (Ok tokens)
        (match (parse-sexpr-all tokens)
          (Err e) (Err e)
          (Ok sexprs) (parse-program sexprs))))

(defn run-fixpoint-test
  :sig [(label : String) (source : String) -> Bool]
  :intent "Compile source twice via bc-compile-program and assert identical BCFunc output"
  :requires [(valid source)]
  :ensures [(valid result)]
  :body
    (match (parse-source source)
      (Err e) (do (print "FAIL:" label "— parse error:" e) false)
      (Ok ast)
        (match (bc-compile-program ast)
          (Err e) (do (print "FAIL:" label "— compile pass 1 error:" e) false)
          (Ok bc1)
            (match (bc-compile-program ast)
              (Err e) (do (print "FAIL:" label "— compile pass 2 error:" e) false)
              (Ok bc2)
                (if (= bc1 bc2)
                  (do (print "PASS:" label) true)
                  (do (print "FAIL:" label "— bytecode differs between runs") false))))))

;; ── Tier 1: Small program fixpoint ──────────────────────

(print "── Tier 1: bc_compiler fixpoint on fixpoint_tier1_program.airl ──")

(let (t1-result : Bool
       (run-fixpoint-test
         "tier 1 fixpoint — bc_compiler determinism on tier1 program"
         (read-file "bootstrap/fixpoint_tier1_program.airl")))
  (print "Tier 1 done, result:" t1-result))

;; ── Tier 2: Self-hosting determinism ────────────────────
;;
;; Compile bc_compiler.airl itself twice via bc-compile-program.
;; If bc_compiler is self-hosting-stable, both passes produce identical BCFunc lists.

(print "── Tier 2: bc_compiler fixpoint on bc_compiler.airl itself ──")

(let (t2-result : Bool
       (run-fixpoint-test
         "tier 2 fixpoint — bc_compiler self-hosting determinism"
         (read-file "bootstrap/bc_compiler.airl")))
  (print "Tier 2 done, result:" t2-result))

(print "fixpoint tests complete")
