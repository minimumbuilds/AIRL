;; mynameisairl.airl — MCP prompt server that teaches AIRL to LLMs
;;
;; Serves AIRL-LLM-Guide.md as an MCP prompt called "teach_airl".
;; Built on the AirTraffic MCP framework with prompt support.

;; ─── mni-parse-args ─────────────────────────────────────────────────
;; Parse CLI args for --guide flag.
;; Returns a map with "guide" key (empty string if not provided).
(defn mni-parse-args
  :sig [-> Map]
  :requires []
  :ensures [(valid result)]
  :body (let (args : List (get-args))
    (let (initial : Map (map-from ["guide" ""]))
      (fold (fn [state arg]
        (let (prev-key : String (map-get-or state "_pending" ""))
          (if (= prev-key "--guide")
            (map-set (map-remove state "_pending") "guide" arg)
            (if (= arg "--guide")
              (map-set state "_pending" arg)
              state))))
        initial args))))

;; ─── mni-resolve-guide-path ─────────────────────────────────────────
;; Resolve guide path: CLI arg > env var > Docker default.
;; Uses getenv which returns Result — falls back on Err.
(defn mni-resolve-guide-path
  :sig [(cli-args : Map) -> String]
  :requires [(valid cli-args)]
  :ensures [(valid result)]
  :body (let (from-cli : String (map-get-or cli-args "guide" ""))
    (if (!= from-cli "")
      from-cli
      (match (getenv "AIRL_GUIDE")
        (Ok from-env) (if (!= from-env "")
          from-env
          "/data/AIRL-LLM-Guide.md")
        (Err _) "/data/AIRL-LLM-Guide.md"))))

;; ─── Top-level entry point ──────────────────────────────────────────
;; Parse args, load guide, register prompt, serve.
(let (cli : Map (mni-parse-args))
  (let (guide-path : String (mni-resolve-guide-path cli))
    (let (guide-text : String (read-file guide-path))
      (let (prompt-def : Map (map-from
        ["name" "teach_airl"
         "description" "Comprehensive AIRL language guide for LLMs — syntax, types, ownership, contracts, builtins, and idioms"
         "arguments" []
         "messages" [(map-from
           ["role" "user"
            "content" (map-from
              ["type" "text"
               "text" guide-text])])
          (map-from
           ["role" "assistant"
            "content" (map-from
              ["type" "text"
               "text" "I know kung-fu."])])]]))
        (let (server : Map (airtraffic-new "mynameisAIRL" "0.1.0" "supervisor" ""))
          (let (server2 : Map (airtraffic-prompt server prompt-def))
            (airtraffic-serve-batch server2 (fn [tool-name args]
              (Err (str "No tools available — this is a prompt-only server"))))))))))
