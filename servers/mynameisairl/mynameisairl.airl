;; mynameisairl.airl — MCP server: AIRL language guide + code intelligence tools
;;
;; Serves:
;;   - teach_airl prompt (AIRL-LLM-Guide.md)
;;   - AirMunch code indexing tools (10 tools for symbol search, xref, etc.)
;;
;; Built on the AirTraffic MCP framework.

;; ─── register-tools-direct ──────────────────────────────────────────
;; Register tool definitions directly, bypassing role check.
;; AirTraffic's role filter only knows workflow_* tools; AirMunch tools
;; are server-specific and always available.
(defn register-tools-direct
  :sig [(server : Map) (tool-defs : List) -> Map]
  :intent "Register tool defs by appending directly to server tools list"
  :requires [(valid server) (valid tool-defs)]
  :ensures [(valid result)]
  :body (let (existing : List (map-get server "tools"))
    (map-set server "tools" (concat existing tool-defs))))

;; ─── Top-level entry point ──────────────────────────────────────────
;; Read guide from file next to the binary, register prompt and tools, serve.
(let (guide-text : String (read-file "AIRL-LLM-Guide.md"))
  (let (prompt-def : Map (map-from
    ["name" "teach_airl"
     "description" "Comprehensive AIRL language guide for LLMs — syntax, types, ownership, contracts, builtins, and idioms"
     "arguments" []
     "messages" [(map-from
       ["role" "user"
        "content" (map-from
          ["type" "text"
           "text" guide-text])])
      (map-from
       ["role" "assistant"
        "content" (map-from
          ["type" "text"
           "text" "I know kung-fu."])])]]))
    ;; Create server with supervisor role
    (let (server : Map (airtraffic-new "mynameisAIRL" (mni-version) "supervisor" ""))
      ;; Register the teach_airl prompt
      (let (server : Map (airtraffic-prompt server prompt-def))
        ;; Register AirMunch tools (bypass role filter — these are server-specific)
        (let (server : Map (register-tools-direct server (make-tool-defs)))
          ;; Create index cache and serve
          (let (cache : Map (map-new))
            (airtraffic-serve-batch server (fn [tool-name args]
              (airmunch-dispatch cache tool-name args)))))))))
