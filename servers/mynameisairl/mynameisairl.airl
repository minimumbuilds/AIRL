;; mynameisairl.airl — MCP prompt + tool server that teaches AIRL to LLMs
;;
;; Serves AIRL-LLM-Guide.md as an MCP prompt called "teach_airl", plus
;; 12 AirMunch indexing tools prefixed "airl_*". Built on the AirTraffic
;; MCP framework. build.sh copies the guide next to the binary and
;; generates _generated.airl with the version string.

;; ─── Top-level entry point ──────────────────────────────────────────
;; Read guide, register prompt + tools, serve.
(let (guide-text : String (read-file "AIRL-LLM-Guide.md"))
     (prompt-def : Map (map-from
       ["name" "teach_airl"
        "description" "Comprehensive AIRL language guide for LLMs — syntax, types, ownership, contracts, builtins, and idioms"
        "arguments" []
        "messages" [(map-from
          ["role" "user"
           "content" (map-from
             ["type" "text"
              "text" guide-text])])
         (map-from
          ["role" "assistant"
           "content" (map-from
             ["type" "text"
              "text" "I know kung-fu."])])]]))
     (allowlist : _ (fn [role name]
       (starts-with name "airl_")))
     (server : Map (airtraffic-new "mynameisAIRL" (mni-version) "" allowlist))
     (server2 : Map (airtraffic-prompt server prompt-def))
     (server3 : Map (airtraffic-tools server2 (make-tool-bindings)))
  (airtraffic-serve server3))
